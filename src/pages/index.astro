---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/home/Hero.astro';
import PainPoint from '../components/sections/home/PainPoint.astro';
import OurWork from '../components/sections/home/OurWork.astro';
import ClientLogos from '../components/sections/ClientLogos.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import PlaceholderBlock from '../components/sections/home/PlaceholderBlock.astro';
import HowWeWork from '../components/sections/home/HowWeWork.astro';
import About from '../components/sections/home/About.astro';
import Footer from '../components/sections/home/Footer.astro';
---
<Base title="Motka Design — Senior design partner" description="UX/UI and branding for complex digital products. Since 2005, 300+ shipped products across SaaS, FinTech, EdTech and beyond.">
  <Nav />
  <main>
    <Hero />
    <PainPoint />
    <OurWork />
    <ClientLogos />
    <div id="testimonials"><Testimonials /></div>
    <PlaceholderBlock />
    <div id="how-we-work"><HowWeWork /></div>
    <About />
  </main>
  <Footer />
</Base>
