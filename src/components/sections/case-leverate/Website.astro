---
// Leverate case — section-website (Figma 1946:508). Тёмный фон, заголовок + абзац сверху,
// затем один высокий композит лендинга (мокапы + свечения) одним PNG на прозрачном фоне.
---
<section class="lc-website">
  <div class="lc-website__inner">

    <div class="lc-website__text">
      <h2 class="lc-website__title">Constructing the website</h2>
      <div class="lc-website__lead">
        <p>First big test was to apply this style to the web.</p>
        <p>In 2 months of redesign we have completely covered the whole company website with the new design.<br />Every product has it's own page. Each page utilizes the same brand components.</p>
        <p>Spacious pages with products in the spotlight and developed visual language to convey marketing value.</p>
      </div>
    </div>

    <div class="lc-website__content">
      <img
        class="lc-website__mockup"
        src="/assets/case-leverate/website-mockup.png"
        alt=""
        aria-hidden="true"
        width="2720"
        height="8481"
        loading="lazy"
      />
    </div>

  </div>
</section>

<style>
  .lc-website {
    width: 100%;
    background: var(--case-bg);
  }
  .lc-website__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Text block ── */
  .lc-website__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Factor A Bold 62px / none, tracking -1.24px */
  .lc-website__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Spectral Regular 24px / 1.34, tracking -0.32px */
  .lc-website__lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
  }
  .lc-website__lead p { margin: 0; }
  .lc-website__lead p + p { margin-top: 20px; }

  /* ── Landing mockup ── */
  /* Композит лендинга: контент 1296 внутри 1360, свечения запечены в PNG и
     выходят за края. Даём ширину 100% контейнера, свечение ложится на тот же тёмный фон. */
  .lc-website__content {
    display: flex;
    justify-content: center;
  }
  .lc-website__mockup {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* ─── адаптив ─── */
  @media (max-width: 768px) {
    .lc-website__inner {
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 48px;
    }
    .lc-website__text { gap: 24px; }
    .lc-website__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-website__lead {
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.32px;
    }
    /* Mockup: full-width, height auto, no overflow */
    .lc-website__content { justify-content: flex-start; }
    .lc-website__mockup {
      width: 100%;
      height: auto;
      border-radius: 24px;
    }
  }
</style>
