---
// Leverate case — section-merch (Figma 1951:1683, 1440×1836).
// Тёмный фон. Заголовок + три абзаца, ниже — merch-grid (PNG) и три фото-карточки.
---
<section class="lc-merch">
  <div class="lc-merch__inner">

    <!-- text block -->
    <div class="lc-merch__text">
      <h2 class="lc-merch__heading">Printing a new reality</h2>
      <div class="lc-merch__lead">
        <p>When a partner picks up a Leverate notebook in Limassol and opens
        <strong>leverate.com</strong> a week later,
        they feel like opening the next chapter of the same conversation.</p>
        <p>T-shirts, notebooks, backpacks, hoodies, powerbanks...<br />
        Designed to feel like a precision tool, not a giveaway.</p>
        <p>Each piece carries a message from the brand: Hi-tech · Innovation · Trust · Customization · Growth</p>
      </div>
    </div>

    <!-- visual content: merch-grid + merch-photos -->
    <div class="lc-merch__content">

      <!-- merch-grid: complex composed mockup (2x PNG, 1360×914 rendered) -->
      <div class="lc-merch__grid-wrap">
        <img
          class="lc-merch__grid"
          src="/assets/case-leverate/merch-grid.png"
          alt="Merch overview — t-shirts and notebooks with Leverate brand identity"
          width="2720"
          height="1828"
          loading="lazy"
        />
      </div>

      <!-- three photo cards -->
      <div class="lc-merch__photos">
        <div class="lc-merch__photo lc-merch__photo--1">
          <img
            src="/assets/case-leverate/merch-photo-1.png"
            alt="Leverate branded laptop setup on a desk"
            width="1024"
            height="1024"
            loading="lazy"
          />
        </div>
        <div class="lc-merch__photo lc-merch__photo--2">
          <img
            src="/assets/case-leverate/merch-photo-2.png"
            alt="Leverate branded backpack with app design detail"
            width="886"
            height="1024"
            loading="lazy"
          />
        </div>
        <div class="lc-merch__photo lc-merch__photo--3">
          <img
            src="/assets/case-leverate/merch-photo-3.png"
            alt="Leverate branded packaging box"
            width="850"
            height="1024"
            loading="lazy"
          />
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .lc-merch {
    width: 100%;
    background: var(--case-bg);
  }
  .lc-merch__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── text block ── */
  .lc-merch__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Factor A Bold 62/1, tracking -1.24px, white */
  .lc-merch__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Literata (Spectral) 24/1.34, tracking -0.32px, white; три абзаца */
  .lc-merch__lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
  }
  .lc-merch__lead p { margin: 0; }
  .lc-merch__lead p + p { margin-top: 20px; }
  .lc-merch__lead strong { font-weight: 700; }

  /* ── visual content ── */
  .lc-merch__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  /* merch-grid: light card on dark bg, 2x PNG fills full width */
  .lc-merch__grid-wrap {
    width: 100%;
    border-radius: 32px;
    overflow: hidden;
    background: #dde1e9;
  }
  .lc-merch__grid {
    display: block;
    width: 100%;
    height: auto;
  }

  /* photo cards row: 3 equal flex items */
  .lc-merch__photos {
    display: flex;
    gap: 20px;
    width: 100%;
    height: 528px;
  }
  .lc-merch__photo {
    flex: 1 0 0;
    min-width: 0;
    border-radius: 32px;
    overflow: hidden;
    position: relative;
  }
  .lc-merch__photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Photo 1: white bg */
  .lc-merch__photo--1 { background: #ffffff; }
  /* Photo 2: gradient top-white → bottom #c1c8d7 */
  .lc-merch__photo--2 { background: linear-gradient(to bottom, #ffffff 2.4%, #c1c8d7); }
  /* Photo 3: white bg */
  .lc-merch__photo--3 { background: #ffffff; }

  /* ─── адаптив ─── */
  @media (max-width: 1024px) {
    .lc-merch__heading { font-size: 48px; }
    .lc-merch__lead { font-size: 20px; }
    .lc-merch__photos { height: 380px; }
  }
  @media (max-width: 768px) {
    .lc-merch__inner {
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 48px;
    }
    .lc-merch__text { gap: 24px; }
    .lc-merch__heading {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-merch__lead {
      font-size: 18px;
      line-height: 1.4;
    }
    .lc-merch__content { gap: 20px; }
    .lc-merch__grid-wrap { border-radius: 32px; }
    .lc-merch__photos {
      flex-direction: column;
      height: auto;
      gap: 20px;
    }
    .lc-merch__photo {
      flex: none;
      width: 100%;
      height: 320px;
      border-radius: 32px;
    }
  }
</style>
