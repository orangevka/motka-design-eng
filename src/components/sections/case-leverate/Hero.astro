---
// Leverate case — section-hero (Figma 1951:1671). Тёмный фон, текст слева,
// мокапы+свечение справа одним PNG (тот же тёмный фон → ложится бесшовно).
---
<section class="lc-hero">
  <div class="lc-hero__inner">
    <img class="lc-hero__visual" src="/assets/case-leverate/hero-mockups.png" alt="" aria-hidden="true" width="1188" height="1116" />

    <div class="lc-hero__text">
      <img class="lc-hero__eyebrow" src="/assets/case-leverate/hero-eyebrow.svg" alt="" aria-hidden="true" width="94" height="109" />
      <h1 class="lc-hero__title">Designing DNA <br />for a fintech <br />platform brand</h1>
      <div class="lc-hero__lead">
        <p>Leverate runs the technology behind hundreds of brokerages worldwide. After 18 years of growth, the brand needed to catch up with the company. We rebuilt it from the atoms into one living system.</p>
        <p>Starting from the brand values. Everything below is how we translated them into a working visual language.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .lc-hero {
    position: relative;
    width: 100%;
    background: var(--case-bg);
    overflow: hidden;
  }
  .lc-hero__inner {
    position: relative;
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    min-height: 807px;
    box-sizing: border-box;
  }

  /* Мокапы + свечение (PNG на тёмном фоне). Позиция относительно контейнера —
     на 1440 и 1600 совпадает; правый bleed клипается overflow:hidden секции. */
  .lc-hero__visual {
    position: absolute;
    top: -260px;
    left: 425px;
    width: 1188px;
    height: auto;
    z-index: 1;
    pointer-events: none;
  }

  .lc-hero__text {
    position: relative;
    z-index: 2;
    padding-top: 120px;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }
  .lc-hero__eyebrow { width: 94px; height: 109px; display: block; }

  /* Factor A Bold 68/76, tracking -1.36px, white */
  .lc-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 68px;
    line-height: 76px;
    letter-spacing: -1.36px;
    color: #fff;
    margin: 0;
  }

  /* Literata 24, lh 1.34, tracking -0.32px, white; два абзаца, отступ 20px */
  .lc-hero__lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
    max-width: 700px;
  }
  .lc-hero__lead p { margin: 0; }
  .lc-hero__lead p + p { margin-top: 20px; }

  /* ─── адаптив (десктоп-даун; точная мобилка — отдельным проходом) ─── */
  @media (max-width: 1200px) {
    .lc-hero__visual { left: auto; right: -120px; width: 980px; top: -180px; }
    .lc-hero__text { max-width: 620px; }
  }
  @media (max-width: 768px) {
    .lc-hero { overflow: hidden; }
    .lc-hero__inner {
      min-height: 0;
      padding-inline: 24px;
      padding-top: 40px;
      padding-bottom: 64px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    /* text block stacks first, then visual below */
    .lc-hero__text {
      order: 1;
      padding-top: 0;
      max-width: none;
      gap: 24px;
    }
    .lc-hero__visual {
      order: 2;
      position: static;
      width: 100%;
      height: auto;
      right: auto;
      top: auto;
      left: auto;
      margin-top: 0;
      display: block;
    }
    .lc-hero__eyebrow { width: 55px; height: auto; }
    .lc-hero__title {
      font-size: 36px;
      line-height: 1.1;
      letter-spacing: -0.72px;
    }
    .lc-hero__lead {
      font-size: 18px;
      line-height: 1.4;
      max-width: none;
    }
  }
</style>
