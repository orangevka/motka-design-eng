---
// Leverate case — section-final-thoughts (Figma 1950:1169). 1440×1238.
// Closing statement + mockup image. Dark bg, Factor A heading, Spectral body.
---
<section class="lc-ft">
  <div class="lc-ft__inner">

    <div class="lc-ft__text">
      <h2 class="lc-ft__title">Final thoughts</h2>
      <div class="lc-ft__body">
        <p>
          8 months rebranding project. Design team of 10.<br />
          A new visual DNA that now runs from the trading terminal to the print booklet.<br />
          From the web pages to office walls.<br />
          <br />
          The marketing team can now ship a new banner, a new brochure, or a new landing page without our involvement.<br />
          The product team can ship new UI features without re-deciding the visual language each time.
        </p>
        <p>
          <strong class="lc-ft__cta"><a href="mailto:orange@motka.design">If you're scaling a multi-product company and your brand is no longer keeping up — let's talk.</a></strong><br />
          <br />
          We know how to build and scale design systems like this.
        </p>
      </div>
    </div>

    <div class="lc-ft__image-wrap">
      <img
        class="lc-ft__image"
        src="/assets/case-leverate/final-thoughts-mockup.png"
        alt="Leverate website shown on a laptop mockup"
        width="2720"
        height="1504"
      />
    </div>

  </div>
</section>

<style>
  .lc-ft {
    width: 100%;
    background: var(--case-bg);
  }

  .lc-ft__inner {
    max-width: var(--container-max); /* 1440px */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 64px;
    align-items: center;
  }

  /* ── Text block ── */
  .lc-ft__text {
    display: flex;
    flex-direction: column;
    gap: 52px;
    align-items: flex-start;
    width: 100%;
  }

  /* Factor A Bold 62/62, tracking -1.24px */
  .lc-ft__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Spectral Regular 24, lh 1.34, tracking -0.32px */
  .lc-ft__body {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
    width: 100%;
  }
  .lc-ft__body p { margin: 0; }
  .lc-ft__body p + p { margin-top: 20px; }

  /* Bold underlined CTA — Spectral Bold with underline */
  .lc-ft__cta {
    font-family: var(--font-serif);
    font-weight: 700;
    font-style: normal;
    text-decoration: underline;
    text-decoration-color: currentColor;
  }
  .lc-ft__cta a {
    color: inherit;
    text-decoration: inherit;
  }

  /* ── Image ── */
  /* Figma: 1360×751.5px at 1440 canvas. Image exported at 2x → 2720×1503. */
  .lc-ft__image-wrap {
    width: 100%;
    border-radius: 32px;
    overflow: hidden;
    aspect-ratio: 1360 / 752;
    flex-shrink: 0;
  }
  .lc-ft__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .lc-ft__inner {
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 48px;
    }
    .lc-ft__text { gap: 32px; }
    .lc-ft__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-ft__body {
      font-size: 18px;
      line-height: 1.4;
    }
    .lc-ft__image-wrap {
      border-radius: 32px;
      aspect-ratio: auto;
      height: 200px;
    }
  }
</style>
