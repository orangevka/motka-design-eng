---
// Leverate case — section-expanding (Figma 1946:507). Тёмный фон, текст + три изображения:
// левое фото (billboard), правый phone-mockup, нижнее широкое фото.
---
<section class="lc-expanding">
  <div class="lc-expanding__inner">

    <div class="lc-expanding__text">
      <h2 class="lc-expanding__title">Expanding on the idea</h2>
      <div class="lc-expanding__lead">
        <p>Once the DNA was set, we let it grow.</p>
        <p>
          The triangle shape became a backdrop.<br />
          The spotlight became a recurring graphic device.<br />
          Glass containers present UIs as precious objects.
        </p>
        <p>Separated elements started to form a distinct visual language.</p>
      </div>
    </div>

    <div class="lc-expanding__content">
      <div class="lc-expanding__row">
        <img
          class="lc-expanding__left"
          src="/assets/case-leverate/expanding-left.png"
          alt=""
          aria-hidden="true"
          width="1162"
          height="1304"
        />
        <img
          class="lc-expanding__phone"
          src="/assets/case-leverate/expanding-phone.png"
          alt=""
          aria-hidden="true"
          width="1527"
          height="1313"
        />
      </div>
      <img
        class="lc-expanding__bottom"
        src="/assets/case-leverate/expanding-bottom.png"
        alt=""
        aria-hidden="true"
        width="2730"
        height="1791"
      />
    </div>

  </div>
</section>

<style>
  .lc-expanding {
    width: 100%;
    background: var(--case-bg);
  }
  .lc-expanding__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    padding-top: 80px;
    padding-bottom: 80px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Text block ── */
  .lc-expanding__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Factor A Bold 62px / none, tracking -1.24px */
  .lc-expanding__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Spectral Regular 24px / 1.34, tracking -0.32px */
  .lc-expanding__lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
  }
  .lc-expanding__lead p { margin: 0; }
  .lc-expanding__lead p + p { margin-top: 20px; }

  /* ── Images ── */
  .lc-expanding__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Top row: left billboard + phone mockup, gap ~15.6px */
  .lc-expanding__row {
    display: flex;
    gap: 15.6px;
    align-items: stretch;
  }

  .lc-expanding__left {
    /* Figma: 580.96 / 1360 total ≈ 42.7% */
    flex: 0 0 42.7%;
    width: 42.7%;
    height: auto;
    border-radius: 32px;
    object-fit: cover;
    display: block;
  }

  .lc-expanding__phone {
    flex: 1 1 0;
    width: 0;
    height: auto;
    border-radius: 32px;
    object-fit: cover;
    display: block;
  }

  /* Bottom full-width image: aspect 1364.84/895.5 */
  .lc-expanding__bottom {
    width: 100%;
    height: auto;
    aspect-ratio: 1364.84 / 895.5;
    border-radius: 32px;
    object-fit: cover;
    display: block;
  }

  /* ─── адаптив ─── */
  @media (max-width: 768px) {
    .lc-expanding__inner {
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 48px;
    }
    .lc-expanding__text { gap: 24px; }
    .lc-expanding__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-expanding__lead {
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.32px;
    }
    /* Images: stack vertically, fixed heights matching Figma mobile */
    .lc-expanding__content { gap: 16px; }
    .lc-expanding__row {
      flex-direction: column;
      gap: 16px;
    }
    .lc-expanding__left {
      flex: none;
      width: 100%;
      height: 400px;
      aspect-ratio: unset;
      border-radius: 24px;
    }
    .lc-expanding__phone {
      flex: none;
      width: 100%;
      height: 300px;
      aspect-ratio: unset;
      border-radius: 24px;
    }
    .lc-expanding__bottom {
      height: auto;
      aspect-ratio: unset;
      border-radius: 24px;
    }
  }
</style>
