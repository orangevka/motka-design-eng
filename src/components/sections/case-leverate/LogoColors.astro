---
// Leverate case — section-logo-colors (Figma 1946:436, 1440×515).
// Dark section: large centered logo wordmark + triangle mark, top strip with
// colour swatches and logo evolution stages, decorative glow/polygon triangle.
---
<section class="lc-lc">
  <!-- Тёплое свечение-прожектор (Figma: rotated polygon, mix-blend-screen).
       Воспроизведено CSS-радиальным градиентом — мягко уходит за правый край,
       без «грубого» обрезания растра. -->
  <div class="lc-lc__glow" aria-hidden="true"></div>

  <div class="lc-lc__inner">

    <!-- Top strip: color swatches + logo evolution stages -->
    <img
      class="lc-lc__top-row"
      src="/assets/case-leverate/logo-colors-top-row.png"
      alt="Brand colour palette and Leverate logo evolution stages"
      width="986"
      height="92"
    />

    <!-- Large centred logo: leverate wordmark + triangle mark -->
    <img
      class="lc-lc__logo"
      src="/assets/case-leverate/logo-colors-logo.png"
      alt="Leverate logo — wordmark with triangle icon"
      width="464"
      height="168"
    />

  </div>
</section>

<style>
  .lc-lc {
    position: relative;
    width: 100%;
    background: var(--case-bg);
    overflow: hidden;
  }

  .lc-lc__inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    /* Figma section height 515px; we replicate via min-height so content fits */
    min-height: 515px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* top-row y≈29px → pad-top to position it correctly */
    padding-top: 29px;
    padding-bottom: 0;
    gap: 0;
  }

  /* ── Top row: centered strip, width 985 on 1440 canvas ── */
  .lc-lc__top-row {
    display: block;
    width: 100%;
    max-width: 986px;
    height: auto;
    position: relative;
    z-index: 2;
  }

  /* ── Large logo centred, starts at y≈286 (286-29=257px below top-row bottom) ──
     top-row height ≈ 92px → gap before logo ≈ 286-29-92 = 165px */
  .lc-lc__logo {
    display: block;
    width: auto;
    max-width: 464px;
    height: auto;
    margin-top: 165px;
    position: relative;
    z-index: 2;
  }

  /* ── Тёплый прожектор: CSS-радиальный градиент, уходит за правый край.
     Центр смещён вправо-вниз, мягкое затухание к прозрачному. ── */
  .lc-lc__glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        58% 82% at 82% 58%,
        rgba(255, 116, 74, 0.55) 0%,
        rgba(255, 96, 62, 0.30) 34%,
        rgba(255, 96, 62, 0.10) 52%,
        rgba(255, 96, 62, 0) 68%
      );
  }

  /* ── Responsive (mobile): match Figma px-24px py-64px, stacked, no overflow ── */
  @media (max-width: 768px) {
    .lc-lc__inner {
      min-height: 0;
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 32px;
    }

    .lc-lc__top-row {
      max-width: 100%;
    }

    .lc-lc__logo {
      margin-top: 0;
      max-width: 240px;
    }

    /* Glow: contained, no horizontal bleed */
    .lc-lc__glow {
      left: 50%;
      transform: translateX(-50%);
      top: auto;
      bottom: -10%;
      width: 100%;
      max-width: 100%;
      opacity: 0.5;
    }
  }
</style>
