---
// Statement section — 1440×96 pixel-perfect (Figma node 15:6495)
// Centered two-line statement: line 1 Bold, line 2 Regular, Factor A 28px lh=40px
---

<section class="statement">
  <div class="container">
    <p class="statement__text">
      <strong class="statement__line1">Good design efficiently connects marketing and development.</strong><br />
      <span class="statement__line2">Design is no longer a roadblock, it helps move things forward.</span>
    </p>
  </div>
</section>

<style>
  .statement {
    width: 100%;
    background: var(--color-bg);
    padding-top: 16px;
  }

  .statement__text {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 40px;
    color: var(--color-ink);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .statement__text {
      font-size: 24px;
      line-height: 34px;
    }
  }

  @media (max-width: 768px) {
    .statement__text {
      font-size: 22px;
      line-height: 32px;
    }
  }

  @media (max-width: 390px) {
    .statement__text {
      font-size: 18px;
      line-height: 26px;
    }
  }

  .statement__line1 {
    font-weight: 700;
  }

  .statement__line2 {
    font-weight: 400;
  }
</style>
