---
// Process section — 1440×682 pixel-perfect (Figma node 15:8493)
// Sand rounded panel with heading + icon row on left; 3-column step cards on right
---

<section class="process">
  <div class="container">
    <div class="process__panel">

      <!-- Top row: heading+icons LEFT, step cards RIGHT -->
      <div class="process__heading-row">

        <!-- Left: heading + icon row -->
        <div class="process__left">
          <h2 class="process__heading">Simple process, predictable flow</h2>
          <div class="process__icons">
            <!-- Figma icon (standalone, no overlap) -->
            <div class="process__icon-wrap process__icon-wrap--first">
              <img src="/assets/process/icon-figma.png" alt="Figma" width="37" height="37" />
            </div>
            <!-- Overlapping group: PS, ID, AI -->
            <div class="process__icon-stack">
              <div class="process__icon-wrap process__icon-wrap--overlap" style="z-index:3">
                <img src="/assets/process/icon-ps.png" alt="Photoshop" width="32" height="32" />
              </div>
              <div class="process__icon-wrap process__icon-wrap--overlap" style="z-index:2">
                <img src="/assets/process/icon-id.png" alt="InDesign" width="32" height="32" />
              </div>
              <div class="process__icon-wrap process__icon-wrap--overlap" style="z-index:1">
                <img src="/assets/process/icon-ai.png" alt="Illustrator" width="42" height="42" />
              </div>
            </div>
            <!-- Zoom -->
            <div class="process__icon-wrap process__icon-wrap--first">
              <img src="/assets/process/icon-zoom.png" alt="Zoom" width="32" height="32" />
            </div>
            <!-- Trello -->
            <div class="process__icon-wrap process__icon-wrap--first">
              <img src="/assets/process/icon-trello.png" alt="Trello" width="37" height="37" />
            </div>
            <!-- Slack -->
            <div class="process__icon-wrap process__icon-wrap--first process__icon-wrap--padded">
              <img src="/assets/process/icon-slack.png" alt="Slack" width="23" height="23" />
            </div>
          </div>
        </div>

        <!-- Right: 3-column steps panel -->
        <div class="process__steps">

          <!-- Step 1: Add tasks to Trello -->
          <div class="process__step">
            <div class="process__mock">
              <img src="/assets/process/step1-trello.png" alt="" width="158" height="180" class="process__mock-img" />
            </div>
            <div class="process__step-text">
              <div class="process__step-num">1</div>
              <div class="process__step-content">
                <p class="process__step-title">Add tasks to Trello</p>
                <p class="process__step-desc">Share context, references, priority. No kickoff call needed for every new request.</p>
              </div>
            </div>
          </div>

          <!-- Divider -->
          <div class="process__divider" aria-hidden="true"></div>

          <!-- Step 2: First drafts in 24–48h -->
          <div class="process__step">
            <div class="process__mock">
              <img src="/assets/process/step2-letsgo.png" alt="" width="240" height="180" class="process__mock-img" />
            </div>
            <div class="process__step-text">
              <div class="process__step-num">2</div>
              <div class="process__step-content">
                <p class="process__step-title">First drafts in 24–48h</p>
                <p class="process__step-desc">Most tasks start moving the same day. Complex projects are split into stages so progress stays visible.</p>
              </div>
            </div>
          </div>

          <!-- Divider -->
          <div class="process__divider" aria-hidden="true"></div>

          <!-- Step 3: Review, iterate, ship -->
          <div class="process__step">
            <div class="process__mock">
              <img src="/assets/process/step3-review.png" alt="" width="240" height="180" class="process__mock-img" />
            </div>
            <div class="process__step-text">
              <div class="process__step-num">3</div>
              <div class="process__step-content">
                <p class="process__step-title">Review, iterate, ship</p>
                <p class="process__step-desc">Comment in Trello, get the next draft within 24h. The next task is already in progress while you review the last.</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Section wrapper ─────────────────────────────────────────── */
  .process {
    width: 100%;
    background: var(--color-bg);
    padding-block: 64px;
  }

  /* ─── Sand rounded panel ──────────────────────────────────────── */
  /* Figma: process block bg #f3efed, radius 24px, padding 36px, gap 0 between children */
  .process__panel {
    background: var(--color-sand);
    border-radius: 24px;
    padding: 36px;
  }

  /* ─── Top-level heading row: left + right ─────────────────────── */
  /* Figma: gap 64px between left column and right steps panel */
  .process__heading-row {
    display: flex;
    align-items: flex-start;
    gap: 64px;
  }

  /* ─── Left column: heading + icons ───────────────────────────── */
  /* Figma: w=325px, flex-col, gap 32px */
  .process__left {
    display: flex;
    flex-direction: column;
    gap: 32px;
    flex-shrink: 0;
    width: 325px;
  }

  /* ─── Heading ─────────────────────────────────────────────────── */
  /* Figma: Factor A Bold 52px / 58px, color #333, w=325px */
  .process__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 52px;
    line-height: 58px;
    color: var(--color-ink);
    margin: 0;
    width: 325px;
  }

  /* ─── Icon row ────────────────────────────────────────────────── */
  /* Figma: gap 6.44px between items */
  .process__icons {
    display: flex;
    align-items: center;
    gap: 6.44px;
  }

  /* Icon wrapper (white bg, rounded, border) */
  .process__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #fff;
    border-radius: 9.66px;
    border: 0.23px solid #fff;
    overflow: hidden;
    flex-shrink: 0;
  }

  .process__icon-wrap--first img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .process__icon-wrap--padded {
    padding: 1px;
  }

  .process__icon-wrap--padded img {
    width: 23px;
    height: 23px;
    object-fit: contain;
  }

  /* Overlapping stack (PS, ID, AI) */
  .process__icon-stack {
    display: flex;
    align-items: center;
  }

  .process__icon-wrap--overlap {
    margin-right: -3.22px;
    border: 1.61px solid #fff;
    width: 32px;
    height: 32px;
    border-radius: 9.66px;
    overflow: hidden;
    position: relative;
  }

  .process__icon-wrap--overlap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  /* ─── Right: steps panel ──────────────────────────────────────── */
  /* Figma: white bg, rounded 24px, overflow:hidden, px=24, py=32, gap=24, flex-row */
  .process__steps {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 24px;
    background: #fff;
    border-radius: 24px;
    overflow: hidden;
    padding: 32px 24px;
  }

  /* ─── Divider between steps ───────────────────────────────────── */
  /* Figma: w=0, self-stretch, with a 1px vertical line via border */
  .process__divider {
    width: 1px;
    align-self: stretch;
    background: var(--color-sand);
    flex-shrink: 0;
  }

  /* ─── Individual step ─────────────────────────────────────────── */
  /* Figma: flex-col, gap 32px, flex:1 */
  .process__step {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ─── Mock area (top of each step) — rasterised Figma mock ─────── */
  .process__mock {
    flex-shrink: 0;
    display: flex;
    justify-content: flex-start;
  }

  .process__mock-img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
  }

  /* ─── Step text row ───────────────────────────────────────────── */
  /* Figma: flex-col, gap 16px */
  .process__step-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ─── Step number badge ───────────────────────────────────────── */
  /* Figma: 32×32, bg #f3efed, border 1px solid white, radius 9.91px, p=4px */
  .process__step-num {
    width: 32px;
    height: 32px;
    background: var(--color-sand);
    border: 1px solid #fff;
    border-radius: 9.91px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 5px;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 18px;
    color: var(--color-ink);
  }

  /* ─── Step content (title + desc) ────────────────────────────── */
  .process__step-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Step title: Factor A Bold 24px / 30px */
  .process__step-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    line-height: 30px;
    color: var(--color-ink);
    margin: 0;
  }

  /* Step desc: Spectral Regular 20px / 24px, ls=-0.4px */
  .process__step-desc {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: normal;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ─── 1280 ───────────────────────────────────────────────────────── */
  @media (max-width: 1280px) {
    .process__heading-row {
      gap: 32px;
    }
    .process__left {
      width: 260px;
    }
    .process__heading {
      font-size: 40px;
      line-height: 46px;
      width: auto;
    }
    .process__steps {
      padding: 24px 16px;
      gap: 16px;
    }
    .process__step-title {
      font-size: 20px;
      line-height: 26px;
    }
    .process__step-desc {
      font-size: 16px;
      line-height: 20px;
    }
  }

  /* ─── 1024 ───────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .process {
      padding-block: 48px;
    }
    .process__panel {
      padding: 24px;
    }
    .process__heading-row {
      gap: 24px;
    }
    .process__left {
      width: 180px;
      gap: 20px;
    }
    .process__icons {
      flex-wrap: wrap;
      gap: 5px;
    }
    .process__heading {
      font-size: 28px;
      line-height: 34px;
    }
    .process__steps {
      padding: 16px 10px;
      gap: 10px;
    }
    .process__step-title {
      font-size: 16px;
      line-height: 20px;
    }
    .process__step-desc {
      font-size: 13px;
      line-height: 17px;
    }
  }

  /* ─── 768: heading on top, 3 image-mocks stay in a row ─────────── */
  @media (max-width: 768px) {
    .process {
      padding-block: 40px;
    }
    .process__panel {
      padding: 24px 20px;
    }
    .process__heading-row {
      flex-direction: column;
      gap: 24px;
    }
    .process__left {
      width: 100%;
      flex-shrink: unset;
      gap: 20px;
    }
    .process__heading {
      font-size: 32px;
      line-height: 38px;
      width: auto;
    }
    .process__steps {
      flex: none; /* в column-heading-row не растягиваем по высоте (иначе overflow режет мокапы) */
      width: 100%;
      padding: 20px 14px;
      gap: 14px;
    }
    .process__step-title {
      font-size: 18px;
      line-height: 24px;
    }
    .process__step-desc {
      font-size: 15px;
      line-height: 20px;
    }
  }

  /* ─── ≤480: phone — 3 mocks too narrow in a row, stack them ──────── */
  @media (max-width: 480px) {
    .process__panel {
      padding: 20px 16px;
    }
    .process__heading {
      font-size: 30px;
      line-height: 36px;
    }
    .process__steps {
      flex-direction: column;
      gap: 0;
      padding: 20px 16px;
    }
    .process__step {
      flex: unset;
      width: 100%;
      gap: 20px;
      padding: 20px 0;
    }
    .process__step:first-child {
      padding-top: 0;
    }
    .process__divider {
      width: 100%;
      height: 1px;
      align-self: auto;
      flex-shrink: 0;
    }
  }

</style>
