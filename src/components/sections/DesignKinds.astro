---
// DesignKinds section — 1440×1060 pixel-perfect (Figma node 15:6497)
// "One subscription, every kind of design"
// CSS-only tabs: clicking a row activates it (radio + :checked). One placeholder
// image for now (dark-card.png); on ≤768 the image opens directly under the active row.
const kinds = [
  { name: 'Interfaces', desc: 'Expert level product design, from screens to design systems.' },
  { name: 'Branding', desc: 'Identity that stays consistent across every touchpoint.' },
  { name: 'Marketing creatives', desc: 'Creative assets for campaigns, launches, and growth.' },
  { name: 'Design support', desc: 'Replaces a part-time in-house designer, without the hire.', outline: true },
];
const ARROW = 'M5 12H19M19 12L13 6M19 12L13 18';
---

<section class="dk">
  <div class="dk__container">

    <!-- Heading -->
    <div class="dk__heading">
      <h2 class="dk__title">One subscription,<br />every kind of design</h2>
    </div>

    <!-- Two-column content — CSS-only tabs -->
    <div class="dk__content">

      <!-- Left: radio-driven design-kind rows -->
      <div class="dk__list">
        {kinds.map((k, i) => (
          <>
            <input class="dk__radio" type="radio" name="dk-tab" id={`dk-tab-${i}`} checked={i === 0} />
            <div class="dk__item">
              <label class:list={['dk__row', k.outline && 'dk__row--outline']} for={`dk-tab-${i}`}>
                <span class="dk__row-inner">
                  <span class="dk__text">
                    <span class="dk__kind-name">{k.name}</span>
                    <span class="dk__kind-desc">{k.desc}</span>
                  </span>
                  <span class="dk__arrow" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d={ARROW} stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </span>
              </label>
              <!-- Per-row image (shown under the active row on ≤768) -->
              <div class="dk__card dk__card--mobile">
                <img src="/assets/designkinds/dark-card.png" alt="" width="785" height="680" class="dk__card-img" aria-hidden="true" />
              </div>
            </div>
          </>
        ))}
      </div>

      <!-- Right: dark card (desktop; reflects the active tab — placeholder image for now) -->
      <div class="dk__card dk__card--desktop">
        <img
          src="/assets/designkinds/dark-card.png"
          alt="Sample design work: Keep Your Challenge fintech modal with UX category navigation"
          width="785"
          height="680"
          class="dk__card-img"
        />
      </div>

    </div>

    <!-- Bottom sentence -->
    <div class="dk__footer">
      <p class="dk__footer-text">
        You don't need four designers for different task types.<br />
        We handle all of it in <span class="dk__highlight"><span class="dk__handle dk__handle--tl"></span><span class="dk__handle dk__handle--tr"></span><span class="dk__handle dk__handle--bl"></span><span class="dk__handle dk__handle--br"></span>one ongoing workflow</span>
      </p>
    </div>

  </div>
</section>

<style>
  /* ─── Section wrapper ───────────────────────────────────────── */
  .dk {
    width: 100%;
    background: var(--color-bg);
    padding: 64px 0;
  }

  .dk__container {
    max-width: var(--container-max); /* 1440px */
    margin: 0 auto;
    padding-inline: var(--container-pad); /* 40px */
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ─── Heading ───────────────────────────────────────────────── */
  .dk__heading {
    width: 100%;
  }

  .dk__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 44px;
    line-height: 46px;
    letter-spacing: 0;
    color: var(--color-ink);
  }

  /* ─── Two-column layout ─────────────────────────────────────── */
  .dk__content {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    width: 100%;
  }

  /* ─── Left: design-kind list ────────────────────────────────── */
  .dk__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 0 0 555px;
    width: 555px;
    position: relative;
    z-index: 4;
  }

  /* Radio inputs (visually hidden, keyboard-focusable) drive the active tab */
  .dk__radio {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    margin: 0;
    pointer-events: none;
  }

  .dk__item {
    display: flex;
    flex-direction: column;
  }

  /* Row card base (label — clickable) */
  .dk__row {
    display: block;
    background: var(--color-sand); /* #f3efed */
    border-radius: 24px;
    padding: 12px;
    width: 100%;
    position: relative;
    cursor: pointer;
  }

  /* Active row (checked radio): white blend overlay */
  .dk__radio:checked + .dk__item .dk__row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    mix-blend-mode: multiply;
    border-radius: 24px;
    pointer-events: none;
  }
  /* Keyboard focus ring on the active/ focused row */
  .dk__radio:focus-visible + .dk__item .dk__row {
    outline: 2px solid #0b99ff;
    outline-offset: 2px;
  }

  /* Outline row: white bg + sand border */
  .dk__row--outline {
    background: white;
    border: 3px solid var(--color-sand);
    padding: 9px; /* 12px - 3px border */
    min-height: 158px;
    display: flex;
    align-items: center;
  }

  .dk__row-inner {
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 24px;
    border-radius: 24px;
    width: 100%;
  }

  /* outline row inner doesn't need extra padding since parent handles it */
  .dk__row--outline .dk__row-inner {
    padding: 24px;
  }

  .dk__text {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1 0 0;
    min-width: 0;
  }

  .dk__kind-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    line-height: 30px;
    color: var(--color-ink);
  }

  .dk__kind-desc {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: -0.4px;
    color: var(--color-text-secondary);
  }

  .dk__arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  /* ─── Dark card ─────────────────────────────────────────────── */
  .dk__card {
    border-radius: 26px;
    overflow: hidden;
    position: relative;
  }
  /* Desktop: single card on the right, reflects active tab */
  .dk__card--desktop {
    flex: 1 1 0;
    height: 680px;
  }
  /* Per-row image: hidden on desktop, revealed under the active row at ≤768 */
  .dk__card--mobile {
    display: none;
  }

  .dk__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 26px;
  }

  /* ─── Bottom text ───────────────────────────────────────────── */
  .dk__footer {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 16px;
  }

  .dk__footer-text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 40px;
    color: var(--color-ink);
    text-align: center;
  }

  /* "one ongoing workflow" — Figma selection-box imitation */
  .dk__highlight {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    line-height: 40px;
    color: var(--color-ink);
    display: inline-block;
    position: relative;
    border: 2px solid #0b99ff;
    border-radius: 0;
    padding: 2px 6px;
    margin-left: 4px;
  }

  /* Corner anchor-point handles */
  .dk__handle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border: 2px solid #0b99ff;
    display: block;
    pointer-events: none;
  }
  /* Centered on the outer corner: outer corner is at -2px (border width),
     8px handle centered = -2px - 4px = -6px from padding-box edge */
  .dk__handle--tl { top: -6px; left: -6px; }
  .dk__handle--tr { top: -6px; right: -6px; }
  .dk__handle--bl { bottom: -6px; left: -6px; }
  .dk__handle--br { bottom: -6px; right: -6px; }

  /* ─── 1280px ────────────────────────────────────────────────── */
  @media (max-width: 1280px) {
    .dk__list {
      flex: 0 0 460px;
      width: 460px;
    }
    .dk__kind-name {
      font-size: 21px;
      line-height: 27px;
    }
    .dk__kind-desc {
      font-size: 17px;
      line-height: 22px;
    }
    .dk__row-inner {
      gap: 20px;
      padding: 20px;
    }
    .dk__card--desktop {
      height: auto;
      align-self: stretch; /* тянемся по высоте списка слева — без пустоты снизу */
    }
  }

  /* ─── 1024px ────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .dk {
      padding-block: 48px;
    }
    .dk__list {
      flex: 0 0 380px;
      width: 380px;
    }
    .dk__title {
      font-size: 36px;
      line-height: 40px;
    }
    .dk__kind-name {
      font-size: 18px;
      line-height: 24px;
    }
    .dk__kind-desc {
      font-size: 15px;
      line-height: 20px;
    }
    .dk__row-inner {
      gap: 12px;
      padding: 16px;
    }
    .dk__row--outline {
      min-height: auto;
    }
    .dk__footer-text {
      font-size: 22px;
      line-height: 32px;
    }
    .dk__highlight {
      font-size: 22px;
      line-height: 32px;
    }
  }

  /* ─── 768px — stack ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .dk {
      padding: 48px 0;
    }
    .dk__container {
      gap: 24px;
    }
    .dk__title {
      font-size: 32px;
      line-height: 36px;
    }
    .dk__content {
      flex-direction: column;
      gap: 24px;
    }
    .dk__list {
      flex: none;
      width: 100%;
    }
    /* Desktop card hidden; the active row's own image opens right under it */
    .dk__card--desktop {
      display: none;
    }
    .dk__card--mobile {
      width: 100%;
      height: auto;
      margin-top: 12px;
      overflow: hidden;
    }
    .dk__radio:checked + .dk__item .dk__card--mobile {
      display: block;
    }
    .dk__card-img {
      width: 100%;
      height: auto;
      max-width: 100%;
      object-fit: initial;
      border-radius: 26px;
    }
    .dk__footer-text {
      font-size: 20px;
      line-height: 28px;
    }
    .dk__highlight {
      font-size: 20px;
      line-height: 28px;
    }
  }

  /* ─── 390px — mobile ────────────────────────────────────────── */
  @media (max-width: 390px) {
    .dk {
      padding: 40px 0;
    }
    .dk__container {
      padding-inline: 20px;
      gap: 20px;
    }
    .dk__title {
      font-size: 26px;
      line-height: 30px;
    }
    .dk__kind-name {
      font-size: 16px;
      line-height: 22px;
    }
    .dk__kind-desc {
      font-size: 14px;
      line-height: 18px;
    }
    .dk__row-inner {
      padding: 12px;
      gap: 8px;
    }
    .dk__row--outline {
      min-height: auto;
    }
    .dk__footer-text {
      font-size: 17px;
      line-height: 24px;
    }
    .dk__highlight {
      font-size: 17px;
      line-height: 24px;
    }
  }

  /* ─── ≤425px ────────────────────────────────────────────────────── */
  @media (max-width: 425px) {
    .dk__row {
      padding: 0;
    }
    .dk__row-inner {
      padding: 16px;
    }
    /* outline row had a more-specific base padding:24 — match it to 16 too */
    .dk__row--outline .dk__row-inner {
      padding: 16px;
    }
  }
</style>
