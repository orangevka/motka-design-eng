---
// ClientLogos section — 1440×182 pixel-perfect (Figma node 15:8343)
// Horizontal row of 5 client logos, evenly spaced/centered
// pt=32, pb=80, px=40; logos row gap=64px, height=70px per logo
---

<section class="client-logos">
  <div class="client-logos__row">

    <!-- leverate: text wordmark (135.6×30.2) + arrow (25.4×22 rotated) -->
    <div class="client-logos__logo client-logos__logo--leverate" aria-label="Leverate">
      <div class="leverate-inner">
        <img
          class="leverate-text"
          src="/assets/logos/leverate-text.svg"
          alt="leverate"
          width="135.599"
          height="30.161"
        />
        <img
          class="leverate-arrow"
          src="/assets/logos/leverate-arrow.svg"
          alt=""
          aria-hidden="true"
          width="21.984"
          height="25.385"
        />
      </div>
    </div>

    <!-- mtx connect: full logo (129.277×52.519) -->
    <div class="client-logos__logo client-logos__logo--mtx" aria-label="MTX Connect">
      <img
        src="/assets/logos/mtx-image.svg"
        alt="MTX Connect"
        width="129.277"
        height="52.519"
      />
    </div>

    <!-- Algoritmika: dark pill logo (168.655×42.563) -->
    <div class="client-logos__logo client-logos__logo--algoritmika" aria-label="Algoritmika">
      <img
        src="/assets/logos/algoritmika.svg"
        alt="Algoritmika"
        width="168.655"
        height="42.563"
      />
    </div>

    <!-- congratz: icon (58.789×60.207) + wordmark text -->
    <div class="client-logos__logo client-logos__logo--congratz" aria-label="congratz">
      <div class="congratz-inner">
        <img
          class="congratz-icon"
          src="/assets/logos/congratz-icon.svg"
          alt=""
          aria-hidden="true"
          width="58.789"
          height="60.207"
        />
        <span class="congratz-text">congratz</span>
      </div>
    </div>

    <!-- hirebus: wordmark (192.612×41.771) -->
    <div class="client-logos__logo client-logos__logo--hirebus" aria-label="hirebus">
      <img
        src="/assets/logos/hirebus.svg"
        alt="hirebus"
        width="192.612"
        height="41.771"
      />
    </div>

  </div>
</section>

<style>
  .client-logos {
    width: 100%;
    background: var(--color-bg);
    padding-top: 32px;
    padding-bottom: 80px;
    padding-left: 40px;
    padding-right: 40px;
    box-sizing: border-box;
  }

  .client-logos__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 64px;
    width: 100%;
  }

  /* Each logo wrapper is 70px tall, centered vertically */
  .client-logos__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 70px;
    flex-shrink: 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */

  /* 1280 — slightly tighter gap */
  @media (max-width: 1280px) {
    .client-logos__row {
      gap: 48px;
    }
  }

  /* 1024 — reduce gap further, allow logos to shrink a little */
  @media (max-width: 1024px) {
    .client-logos {
      padding-bottom: 56px;
    }
    .client-logos__row {
      gap: 24px 36px; /* вертикальный 24 при переносе, горизонтальный 36 */
    }
    .client-logos__logo {
      flex-shrink: 1;
    }
  }

  /* 768 — wrap to 2-3 per row, scale logos down */
  @media (max-width: 768px) {
    .client-logos {
      padding-left: 24px;
      padding-right: 24px;
    }
    .client-logos__row {
      gap: 28px 32px;
    }
    .client-logos__logo {
      height: 56px;
    }
    .leverate-inner {
      transform: scale(0.82);
      transform-origin: center center;
    }
    .client-logos__logo--mtx img,
    .client-logos__logo--algoritmika img,
    .client-logos__logo--hirebus img {
      width: auto;
      height: 36px;
    }
    .client-logos__logo--algoritmika {
      width: auto;
    }
    .client-logos__logo--congratz {
      width: auto;
      overflow: visible;
    }
    .congratz-icon {
      width: 48px;
      height: auto;
    }
    .congratz-text {
      font-size: 23px;
      margin-left: 46px;
      margin-top: 9px;
    }
  }

  /* 390 — mobile: 2 per row, smaller gap */
  @media (max-width: 390px) {
    .client-logos {
      padding-left: 16px;
      padding-right: 16px;
      padding-bottom: 48px;
    }
    .client-logos__row {
      gap: 20px 24px;
    }
    .client-logos__logo {
      height: 48px;
    }
    .leverate-inner {
      transform: scale(0.68);
      transform-origin: center center;
    }
    .client-logos__logo--mtx img,
    .client-logos__logo--algoritmika img,
    .client-logos__logo--hirebus img {
      height: 30px;
    }
    .congratz-icon {
      width: 40px;
    }
    .congratz-text {
      font-size: 19px;
      margin-left: 38px;
      margin-top: 7px;
    }
  }

  /* Leverate: relative container holding text + rotated arrow */
  .leverate-inner {
    position: relative;
    width: 138.529px;
    height: 50.242px;
  }

  .leverate-text {
    position: absolute;
    left: 0;
    top: 11.05px;
    width: 135.599px;
    height: 30.161px;
    display: block;
  }

  /* Arrow: rotated 90°, positioned at left=116.55, top=-9.03 (relative to inner container) */
  .leverate-arrow {
    position: absolute;
    left: 116.55px;
    top: -9.03px;
    width: 21.984px;
    height: 25.385px;
    transform: rotate(90deg);
    transform-origin: 50% 50%;
    display: block;
  }

  /* MTX logo */
  .client-logos__logo--mtx img {
    width: 129.277px;
    height: 52.519px;
    display: block;
  }

  /* Algoritmika: fixed size */
  .client-logos__logo--algoritmika {
    width: 168.226px;
  }
  .client-logos__logo--algoritmika img {
    width: 168.655px;
    height: 42.563px;
    display: block;
  }

  /* congratz: icon + text overlay in a grid */
  .client-logos__logo--congratz {
    width: 184.032px;
    overflow: hidden;
  }

  .congratz-inner {
    display: grid;
    grid-template-columns: max-content;
    grid-template-rows: max-content;
    position: relative;
  }

  .congratz-icon {
    grid-column: 1;
    grid-row: 1;
    width: 58.789px;
    height: 60.207px;
    display: block;
  }

  .congratz-text {
    grid-column: 1;
    grid-row: 1;
    position: relative;
    margin-left: 56.53px;
    margin-top: 11.29px;
    font-family: 'Outfit', 'Factor A', system-ui, sans-serif;
    font-weight: 600;
    font-size: 28.7px;
    line-height: normal;
    color: #262626;
    white-space: nowrap;
  }

  /* hirebus */
  .client-logos__logo--hirebus img {
    width: 192.612px;
    height: 41.771px;
    display: block;
  }

  /* ── Мобильная бегущая строка (≤768) ───────────────────────────
     Класс --marquee вешает JS после клонирования логотипов; без JS
     остаётся обычный перенос (graceful fallback). Трек = 2 копии набора,
     translateX(-50%) даёт бесшовный цикл; интервал через margin-right
     (а не gap), чтобы 50% точно совпадало по ширине. */
  @media (max-width: 768px) {
    .client-logos--marquee {
      padding-left: 0;
      padding-right: 0;
      overflow: hidden;
    }
    .client-logos--marquee .client-logos__row {
      flex-wrap: nowrap;
      justify-content: flex-start;
      width: max-content;
      gap: 0;
      animation: logos-marquee 22s linear infinite;
      will-change: transform;
    }
    .client-logos--marquee .client-logos__logo {
      flex-shrink: 0;
      margin-right: 24px;
    }
  }

  @keyframes logos-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-logos--marquee .client-logos__row { animation: none; }
  }
</style>

<script>
  // На мобиле (≤768) показываем логотипы бегущей строкой: клонируем набор
  // один раз (для бесшовного -50%) и включаем класс --marquee. На десктопе
  // клоны убираем и возвращаем обычный центрированный ряд.
  const cl = document.querySelector('.client-logos');
  if (cl) {
    const row = cl.querySelector('.client-logos__row') as HTMLElement;
    const mq = window.matchMedia('(max-width: 768px)');
    const originals = Array.from(row.children);
    let cloned = false;

    const setup = () => {
      if (mq.matches && !cloned) {
        originals.forEach((n) => {
          const c = n.cloneNode(true) as HTMLElement;
          c.setAttribute('aria-hidden', 'true');
          row.appendChild(c);
        });
        cloned = true;
        cl.classList.add('client-logos--marquee');
      } else if (!mq.matches && cloned) {
        Array.from(row.children).slice(originals.length).forEach((c) => c.remove());
        cloned = false;
        cl.classList.remove('client-logos--marquee');
      }
    };

    setup();
    mq.addEventListener('change', setup);
  }
</script>
