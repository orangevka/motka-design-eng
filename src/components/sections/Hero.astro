---
// Hero section — 1440×650 pixel-perfect (Figma node 15:334)
// Card strip is animation-ready: overflow:hidden viewport + .hero-strip__track flex row
---

<section class="hero">
  <!-- Centered inner wrapper — max-width 1440, clips imagery at the 1440 column's right edge.
       All absolute-positioned children are now relative to this wrapper, not the viewport. -->
  <div class="hero__inner">
    <!-- Decorative background shape (x=-68,y=52 relative to wrapper, w=920 h=552) -->
    <div class="hero__deco" aria-hidden="true">
      <img src="/assets/hero/decorative-shape.svg" alt="" width="920" height="552" />
    </div>

    <!-- Text + nav content block (x=40,y=80 in wrapper, w=900) -->
    <div class="hero__content">
      <div class="hero__heading">
        <h1 class="hero__title">Design<br />Subscription</h1>
        <p class="hero__subtitle">Fixed monthly price. Pause anytime</p>
      </div>

      <!-- "For" label + audience chips -->
      <div class="hero__audience">
        <span class="hero__for-label">For</span>
        <div class="hero__chips">
          <div class="hero__chip">
            <img src="/assets/hero/nav-startups.svg" alt="" width="24" height="24" aria-hidden="true" />
            <span>Startups</span>
          </div>
          <div class="hero__chip">
            <img src="/assets/hero/nav-product.svg" alt="" width="24" height="24" aria-hidden="true" />
            <span>Product marketing</span>
          </div>
          <div class="hero__chip">
            <img src="/assets/hero/nav-growing.svg" alt="" width="24" height="24" aria-hidden="true" />
            <span>Growing companies</span>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA buttons (x=40, y=444 in wrapper) -->
    <div class="hero__actions">
      <a href="/contacts.html" class="hero__btn hero__btn--primary">Book a call</a>
      <a href="/#plans" class="hero__btn hero__btn--outline">See plans</a>
    </div>

  </div>

  <!-- Card strip — direct child of .hero (NOT inside .hero__inner) so it is NOT
       clipped at the 1440-column right edge. .hero { overflow:hidden } clips it
       at the viewport edge instead. Left position mirrors 429px from the column's
       left edge: calc(50% - 720px + 429px) = calc(50% - 291px). -->
  <!-- stage ④: animate __track horizontally (marquee). Static offset for now. -->
  <div class="hero-strip" aria-hidden="true">
    <div class="hero-strip__track">
      <!-- Cards 1-2: detailed composites matching Figma (15:336, 15:340) -->
      <div class="hero-strip__card">
        <img src="/assets/hero/card-1.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-2.png" alt="" width="400" height="530" />
      </div>
      <!-- Cards 3-11: portfolio work samples (animation track filler) -->
      <div class="hero-strip__card">
        <img src="/assets/hero/card-720.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-721.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-722.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-723.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-724.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-725.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-726.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-727.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-728.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-729.png" alt="" width="400" height="530" />
      </div>
      <div class="hero-strip__card">
        <img src="/assets/hero/card-730.png" alt="" width="400" height="530" />
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Hero section ────────────────────────────────────────────── */
  /* overflow:hidden clips the card strip at the viewport edge (right-bleed).
     position:relative is the positioning context for .hero-strip. */
  .hero {
    position: relative;
    width: 100%;
    height: 650px;
    background: var(--color-bg);
    overflow: hidden;
  }

  /* ─── Centered inner wrapper ──────────────────────────────────── */
  /* overflow removed — strip is now a sibling, not a child, so this
     wrapper no longer clips it. Text/deco/gradient remain here. */
  .hero__inner {
    position: relative;
    width: 100%;
    max-width: 1440px;
    height: 100%;
    margin-inline: auto;
    z-index: 2; /* forms stacking context above .hero-strip (z=1) */
  }

  /* ─── White mask — keeps carousel hidden until x≈597 ─────────── */
  /* Figma: colorful imagery only reveals at x≈597 (card strip x=429
     is fully masked). This ::before covers [0..557] solid white then
     fades to transparent over the next 40px, reaching transparent at
     x=597 — matching Figma's reveal point.
     Placed on __inner so gradient coords are relative to the 1440 column.
     z-index: 2 — above card strip (z=1), below text (z=3). */
  .hero__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #ffffff 0px,
      #ffffff 557px,
      transparent 597px
    );
    pointer-events: none;
    z-index: 2;
  }

  /* ─── Decorative background shape ────────────────────────────── */
  /* Figma: x=-68, y=52, w=920, h=552 (relative to section origin).
     Radial gradient (white→transparent) reinforces the soft blend
     between white text area and the card strip.
     z-index: 2 (same layer as ::before mask). */
  .hero__deco {
    position: absolute;
    left: -68px;
    top: 52px;
    width: 920px;
    height: 552px;
    pointer-events: none;
    z-index: 2;
  }
  .hero__deco img {
    width: 920px;
    height: 552px;
  }

  /* ─── Content block (heading + audience) ─────────────────────── */
  /* Figma: Frame 2131328137 at x=40, y=80, w=900, h=300.
     Heading (h=228) + 32px gap + Nav Items (h=40) = 300px total.
     left=34px: the 'D' glyph has ~8px left side-bearing so the visible
     text edge lands at 34+8=42px, aligning with other .container sections
     (which use padding-inline:40px → text glyph at ~42px).
     z-index: 3 so text sits above the deco gradient. */
  .hero__content {
    position: absolute;
    left: 34px;
    top: 80px;
    width: 900px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    z-index: 3;
  }

  .hero__heading {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Heading: "Design Subscription" — 80px Bold, lh=80px, Factor A */
  .hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 80px;
    line-height: 80px;
    letter-spacing: -0.5px;
    color: var(--color-ink);
    width: 900px;
    /* 2 lines × 80px = 160px total */
  }

  /* Subtitle: 40px Regular, lh=52px */
  .hero__subtitle {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 40px;
    line-height: 52px;
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* ─── Audience chips ("For …") ────────────────────────────────── */
  /* Figma: gap=16px between "For" label and container; chips gap=8px */
  .hero__audience {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero__for-label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 18px;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .hero__chips {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero__chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--color-sand); /* #f3efed */
    border-radius: var(--radius-2xl); /* 16px */
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    line-height: 20px;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .hero__chip img {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  /* ─── CTA Buttons ─────────────────────────────────────────────── */
  /* Figma: x=40, y=444, w=311, h=60; gap=8px between buttons.
     left=34px: matches hero__content alignment (glyph at ~42px).
     z-index: 3 so buttons sit above the deco gradient overlay. */
  .hero__actions {
    position: absolute;
    left: 34px;
    top: 444px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 3;
  }

  .hero__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-2xl); /* 16px */
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 24px;
    text-decoration: none;
    white-space: nowrap;
  }

  /* Primary button: dark bg, 156×60 */
  .hero__btn--primary {
    background: var(--color-ink); /* #333 */
    color: #fff;
    padding: 20px 32px 16px; /* pt=20, pb=16, px=32 → h=60 */
    width: 156px;
  }

  /* Outline button: transparent bg + border, 147×60 */
  .hero__btn--outline {
    background: transparent;
    color: #262626;
    border: 2px solid #d6ccc7;
    padding: 18px 32px 14px; /* compensate 2px border: 20-2=18 pb=16-2=14 */
    width: 147px;
  }

  /* ─── Card strip ──────────────────────────────────────────────── */
  /*
   * Figma: card works at x=429, y=60, width=4559, height=530
   * We want: viewport starts at x=429 from section left,
   * extending to right edge (1440-429=1011px wide viewport)
   * Cards are 400px wide with ~14.79px gap → total track ~4559px
   */

  /* Card strip — positioned relative to .hero (viewport-width).
     Left edge mirrors 429px from the centered 1440-column's left edge:
       column left = calc(50% - 720px)
       strip left  = calc(50% - 720px + 429px) = calc(50% - 291px)
     At 1440vw: 720-291 = 429px ✓ (identical to before)
     At 1920vw: 960-291 = 669px — strip starts at 669px, runs to right edge.
     overflow:visible — .hero clips at viewport edge.
     z-index: 1 — below deco (z=2) and content (z=3). */
  .hero-strip {
    position: absolute;
    left: calc(50% - 291px);
    top: 60px;
    width: calc(100% - (50% - 291px)); /* extends to .hero right edge */
    height: 530px;
    overflow: visible;
    z-index: 1;
  }

  /* Single flex row holding all cards */
  /* stage ④: animate __track horizontally (marquee). Static offset for now. */
  .hero-strip__track {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 14.79px; /* Figma gap between cards in strip (414.79-400=14.79) */
    width: max-content;
    height: 530px;
    /* Static: show from start (leftmost visible card aligns with left edge) */
    transform: translateX(0);
  }

  .hero-strip__card {
    width: 400px;
    height: 530px;
    flex-shrink: 0;
    border-radius: 26px;
    overflow: hidden;
  }

  .hero-strip__card img {
    width: 400px;
    height: 530px;
    object-fit: cover;
    display: block;
  }

  /* ─── Responsive: 1280 ────────────────────────────────────────── */
  @media (max-width: 1279px) {
    .hero__title {
      font-size: 72px;
      line-height: 72px;
      width: auto;
    }
    .hero__subtitle {
      font-size: 34px;
      line-height: 44px;
    }
    /* Keep content within viewport */
    .hero__content {
      width: calc(100% - 68px); /* 34px left + 34px right breathing room */
      max-width: 540px;
    }
  }

  /* ─── Responsive: 1024 ────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .hero {
      height: 600px;
    }
    .hero__title {
      font-size: 60px;
      line-height: 62px;
    }
    .hero__subtitle {
      font-size: 28px;
      line-height: 36px;
    }
    .hero__chip {
      font-size: 17px;
      line-height: 17px;
    }
    .hero__content {
      max-width: 460px;
    }
    .hero__actions {
      top: 410px;
    }
  }

  /* ─── Responsive: 768 and below ──────────────────────────────── */
  /* Layout: stacked — text block on top (static flow), card strip
     below as a full-width clipped band. Hero becomes auto-height. */
  @media (max-width: 768px) {
    .hero {
      height: auto;
      overflow: hidden;
    }

    /* Inner wrapper: static flow, auto height */
    .hero__inner {
      height: auto;
      padding: 40px 24px 0;
    }

    /* Remove the white gradient mask — not needed in stacked layout */
    .hero__inner::before {
      display: none;
    }

    /* Deco shape: hide on mobile — it's positioned for desktop overlap */
    .hero__deco {
      display: none;
    }

    /* Content: static flow (not absolute), full width */
    .hero__content {
      position: static;
      width: 100%;
      max-width: 100%;
      top: auto;
      left: auto;
      gap: 24px;
    }

    .hero__title {
      font-size: clamp(36px, 10vw, 52px);
      line-height: 1;
      width: auto;
    }

    .hero__subtitle {
      font-size: clamp(20px, 5.5vw, 28px);
      line-height: 1.35;
      white-space: normal;
    }

    /* Audience chips: allow wrap */
    .hero__audience {
      flex-wrap: wrap;
      gap: 12px;
    }
    .hero__chips {
      flex-wrap: wrap;
      gap: 8px;
    }
    .hero__chip {
      font-size: 16px;
      line-height: 16px;
    }

    /* CTA buttons: static flow below content */
    .hero__actions {
      position: static;
      top: auto;
      left: auto;
      margin-top: 24px;
      padding-bottom: 32px;
    }

    /* Buttons: tappable ≥44px */
    .hero__btn {
      min-height: 44px;
      padding: 10px 28px;
    }
    .hero__btn--primary {
      width: auto;
      padding: 10px 28px;
    }
    .hero__btn--outline {
      width: auto;
      padding: 8px 28px;
    }

    /* Card strip: full-width band, clipped, below text */
    .hero-strip {
      position: static;
      left: auto;
      top: auto;
      width: 100%;
      height: 260px;
      overflow: hidden;
      margin-top: 24px;
    }

    .hero-strip__track {
      height: 260px;
      gap: 10px;
    }

    .hero-strip__card {
      width: 200px;
      height: 260px;
      border-radius: 16px;
    }
    .hero-strip__card img {
      width: 200px;
      height: 260px;
    }
  }

  /* ─── Responsive: 390 (small mobile) ─────────────────────────── */
  @media (max-width: 430px) {
    .hero__inner {
      padding: 32px 16px 0;
    }

    .hero__title {
      font-size: clamp(32px, 9vw, 40px);
    }

    .hero__subtitle {
      font-size: clamp(18px, 5vw, 22px);
    }

    .hero__chip {
      font-size: 14px;
      line-height: 14px;
      padding: 6px 10px;
    }

    .hero-strip {
      height: 220px;
    }
    .hero-strip__track {
      height: 220px;
    }
    .hero-strip__card {
      width: 170px;
      height: 220px;
    }
    .hero-strip__card img {
      width: 170px;
      height: 220px;
    }
  }
</style>
