---
// DesignKinds section — 1440×1060 pixel-perfect (Figma node 15:6497)
// "One subscription, every kind of design"
---

<section class="dk">
  <div class="dk__container">

    <!-- Heading -->
    <div class="dk__heading">
      <h2 class="dk__title">One subscription,<br />every kind of design</h2>
    </div>

    <!-- Two-column content -->
    <div class="dk__content">

      <!-- Left: design kind rows -->
      <div class="dk__list">

        <!-- Interfaces (active / elevated) -->
        <div class="dk__row dk__row--active">
          <div class="dk__row-inner">
            <div class="dk__text">
              <p class="dk__kind-name">Interfaces</p>
              <p class="dk__kind-desc">Expert level product design, from screens<br />to design systems.</p>
            </div>
            <div class="dk__arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Branding -->
        <div class="dk__row">
          <div class="dk__row-inner">
            <div class="dk__text">
              <p class="dk__kind-name">Branding</p>
              <p class="dk__kind-desc">Identity that stays consistent across every touchpoint.</p>
            </div>
            <div class="dk__arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Marketing creatives -->
        <div class="dk__row">
          <div class="dk__row-inner">
            <div class="dk__text">
              <p class="dk__kind-name">Marketing creatives</p>
              <p class="dk__kind-desc">Creative assets for campaigns, launches,<br />and growth.</p>
            </div>
            <div class="dk__arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Design support (white, outlined) -->
        <div class="dk__row dk__row--outline">
          <div class="dk__row-inner">
            <div class="dk__text">
              <p class="dk__kind-name">Design support</p>
              <p class="dk__kind-desc">Replaces a part-time in-house designer, without the hire.</p>
            </div>
            <div class="dk__arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

      </div>

      <!-- Right: dark card -->
      <div class="dk__card">
        <img
          src="/assets/designkinds/dark-card.png"
          alt="Sample design work: Keep Your Challenge fintech modal with UX category navigation"
          width="785"
          height="680"
          class="dk__card-img"
        />
      </div>

    </div>

    <!-- Bottom sentence -->
    <div class="dk__footer">
      <p class="dk__footer-text">
        You don't need four designers for different task types.<br />
        We handle all of it in <span class="dk__highlight"><span class="dk__handle dk__handle--tl"></span><span class="dk__handle dk__handle--tr"></span><span class="dk__handle dk__handle--bl"></span><span class="dk__handle dk__handle--br"></span>one ongoing workflow</span>
      </p>
    </div>

  </div>
</section>

<style>
  /* ─── Section wrapper ───────────────────────────────────────── */
  .dk {
    width: 100%;
    background: var(--color-bg);
    padding: 64px 0;
  }

  .dk__container {
    max-width: var(--container-max); /* 1440px */
    margin: 0 auto;
    padding-inline: var(--container-pad); /* 40px */
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ─── Heading ───────────────────────────────────────────────── */
  .dk__heading {
    width: 100%;
  }

  .dk__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 44px;
    line-height: 46px;
    letter-spacing: 0;
    color: var(--color-ink);
  }

  /* ─── Two-column layout ─────────────────────────────────────── */
  .dk__content {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    width: 100%;
  }

  /* ─── Left: design-kind list ────────────────────────────────── */
  .dk__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 0 0 555px;
    width: 555px;
    position: relative;
    z-index: 4;
  }

  /* Row card base */
  .dk__row {
    background: var(--color-sand); /* #f3efed */
    border-radius: 24px;
    padding: 12px;
    width: 100%;
    position: relative;
  }

  /* Active row: white blend overlay */
  .dk__row--active::before {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    mix-blend-mode: multiply;
    border-radius: 24px;
    pointer-events: none;
  }

  /* Outline row: white bg + sand border */
  .dk__row--outline {
    background: white;
    border: 3px solid var(--color-sand);
    padding: 9px; /* 12px - 3px border */
    min-height: 158px;
    display: flex;
    align-items: center;
  }

  .dk__row-inner {
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 24px;
    border-radius: 24px;
    width: 100%;
  }

  /* outline row inner doesn't need extra padding since parent handles it */
  .dk__row--outline .dk__row-inner {
    padding: 24px;
  }

  .dk__text {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1 0 0;
    min-width: 0;
  }

  .dk__kind-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    line-height: 30px;
    color: var(--color-ink);
  }

  .dk__kind-desc {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: -0.4px;
    color: var(--color-text-secondary);
  }

  .dk__arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  /* ─── Right: dark card ──────────────────────────────────────── */
  .dk__card {
    flex: 1 1 0;
    height: 680px;
    border-radius: 26px;
    overflow: hidden;
    position: relative;
  }

  .dk__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 26px;
  }

  /* ─── Bottom text ───────────────────────────────────────────── */
  .dk__footer {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 16px;
  }

  .dk__footer-text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 40px;
    color: var(--color-ink);
    text-align: center;
  }

  /* "one ongoing workflow" — Figma selection-box imitation */
  .dk__highlight {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    line-height: 40px;
    color: var(--color-ink);
    display: inline-block;
    position: relative;
    border: 2px solid #0b99ff;
    border-radius: 0;
    padding: 2px 6px;
    margin-left: 4px;
  }

  /* Corner anchor-point handles */
  .dk__handle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border: 2px solid #0b99ff;
    display: block;
    pointer-events: none;
  }
  /* Centered on the outer corner: outer corner is at -2px (border width),
     8px handle centered = -2px - 4px = -6px from padding-box edge */
  .dk__handle--tl { top: -6px; left: -6px; }
  .dk__handle--tr { top: -6px; right: -6px; }
  .dk__handle--bl { bottom: -6px; left: -6px; }
  .dk__handle--br { bottom: -6px; right: -6px; }

  /* ─── 1280px ────────────────────────────────────────────────── */
  @media (max-width: 1280px) {
    .dk__list {
      flex: 0 0 460px;
      width: 460px;
    }
    .dk__kind-name {
      font-size: 21px;
      line-height: 27px;
    }
    .dk__kind-desc {
      font-size: 17px;
      line-height: 22px;
    }
    .dk__row-inner {
      gap: 20px;
      padding: 20px;
    }
    .dk__card {
      height: auto;
      aspect-ratio: 785 / 680;
    }
  }

  /* ─── 1024px ────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .dk__list {
      flex: 0 0 380px;
      width: 380px;
    }
    .dk__title {
      font-size: 36px;
      line-height: 40px;
    }
    .dk__kind-name {
      font-size: 18px;
      line-height: 24px;
    }
    .dk__kind-desc {
      font-size: 15px;
      line-height: 20px;
    }
    .dk__row-inner {
      gap: 12px;
      padding: 16px;
    }
    .dk__row--outline {
      min-height: auto;
    }
    .dk__footer-text {
      font-size: 22px;
      line-height: 32px;
    }
    .dk__highlight {
      font-size: 22px;
      line-height: 32px;
    }
  }

  /* ─── 768px — stack ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .dk {
      padding: 48px 0;
    }
    .dk__container {
      gap: 24px;
    }
    .dk__title {
      font-size: 32px;
      line-height: 36px;
    }
    .dk__content {
      flex-direction: column;
      gap: 24px;
    }
    .dk__list {
      flex: none;
      width: 100%;
    }
    .dk__card {
      flex: none;
      width: 100%;
      height: auto;
      aspect-ratio: unset;
      overflow: visible;
    }
    .dk__card-img {
      width: 100%;
      height: auto;
      max-width: 100%;
      object-fit: initial;
      border-radius: 26px;
    }
    .dk__footer-text {
      font-size: 20px;
      line-height: 28px;
    }
    .dk__highlight {
      font-size: 20px;
      line-height: 28px;
    }
  }

  /* ─── 390px — mobile ────────────────────────────────────────── */
  @media (max-width: 390px) {
    .dk {
      padding: 40px 0;
    }
    .dk__container {
      padding-inline: 20px;
      gap: 20px;
    }
    .dk__title {
      font-size: 26px;
      line-height: 30px;
    }
    .dk__kind-name {
      font-size: 16px;
      line-height: 22px;
    }
    .dk__kind-desc {
      font-size: 14px;
      line-height: 18px;
    }
    .dk__row-inner {
      padding: 12px;
      gap: 8px;
    }
    .dk__row--outline {
      min-height: auto;
    }
    .dk__footer-text {
      font-size: 17px;
      line-height: 24px;
    }
    .dk__highlight {
      font-size: 17px;
      line-height: 24px;
    }
  }
</style>
