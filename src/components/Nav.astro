---
const cases = [
  { label: 'Chitai-Gorod',  href: '/portfolio/chitay-gorod.html' },
  { label: 'Logistic SaaS', href: '/portfolio/logistic-saas-platform.html' },
  { label: 'MTX Connect',   href: '/portfolio/mtx-connect.html' },
  { label: 'DeepGeo',       href: '/portfolio/deepgeo.html' },
  { label: 'Journey',       href: '/portfolio/ai-body.html' },
  { label: 'Algorithmics',  href: '/portfolio/algoritmika.html' },
  { label: 'Spherum',       href: '/portfolio/spherum.html' },
  { label: 'Congratz',      href: '/portfolio/congratz.html' },
  { label: 'SCAN',          href: '/portfolio/scan.html' },
  { label: 'GlobalLab',     href: '/portfolio/globallab.html' },
  { label: 'SweepNet',      href: '/portfolio/sweep-net.html' },
  { label: 'RealAtom',      href: '/portfolio/realatom.html' },
  { label: 'IDX',           href: '/portfolio/idx.html' },
  { label: 'MoneyWall',     href: '/portfolio/moneywall.html' },
  { label: 'PokerSwap',     href: '/portfolio/pokerswap.html' },
  { label: 'Dunice',        href: '/portfolio/dunice.html' },
  { label: 'Foodbuddy',     href: '/portfolio/foodbuddy.html' },
  { label: 'News360',       href: '/portfolio/news360.html' },
];
const allCasesHref = '/portfolio.html';

const links = [
  { label: 'Portfolio', href: '/portfolio.html', dropdown: true },
  { label: 'About', href: '/about.html' },
  { label: 'Design Subscription', href: '/' },
  { label: 'Contact us', href: '/contacts.html' },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__logo" href="/" aria-label="Motka Design — home">
      <img src="/assets/nav/logo.svg" width="133" height="50" alt="Motka Design" />
    </a>

    <!-- Desktop nav (≥768px) -->
    <nav class="site-nav" aria-label="Primary">
      {links.map((l) => (
        <a class:list={['site-nav__item', l.dropdown && 'site-nav__item--dropdown']} href={l.href}>
          {l.label}
          {l.dropdown && (
            <img class="site-nav__chevron" src="/assets/nav/chevron.svg" width="20" height="20" alt="" aria-hidden="true" />
          )}
        </a>
      ))}
    </nav>

    <!-- Mobile nav (<768px): details/summary CSS-only hamburger -->
    <details class="mobile-nav">
      <summary class="mobile-nav__toggle" aria-label="Open menu">
        <!-- Hamburger icon (three bars) -->
        <svg class="mobile-nav__icon mobile-nav__icon--open" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3" y="6"  width="18" height="2" rx="1" fill="currentColor"/>
          <rect x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
          <rect x="3" y="16" width="18" height="2" rx="1" fill="currentColor"/>
        </svg>
        <!-- Close icon (×) -->
        <svg class="mobile-nav__icon mobile-nav__icon--close" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="19" y1="5" x2="5"  y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </summary>
      <nav class="mobile-nav__menu" aria-label="Mobile primary">
        {links.map((l) => (
          <a class:list={['mobile-nav__item', l.dropdown && 'mobile-nav__item--dropdown']} href={l.href}>
            {l.label}
            {l.dropdown && (
              <img class="mobile-nav__chevron" src="/assets/nav/chevron.svg" width="20" height="20" alt="" aria-hidden="true" />
            )}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  /* ── Shared header shell ─────────────────────────────── */
  .site-header { width: 100%; background: var(--color-bg); }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-5); /* 20px → total height 90px (50 + 20*2) */
  }
  .site-header__logo { display: block; flex-shrink: 0; }
  .site-header__logo img { width: 133px; height: 50px; }

  /* ── Desktop nav (always rendered, hidden on mobile) ── */
  .site-nav { display: flex; align-items: center; gap: var(--space-7); /* 28px */ }
  .site-nav__item {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 20px;
    letter-spacing: -0.56px;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .site-nav__item--dropdown { display: inline-flex; align-items: center; gap: var(--space-1); /* 4px */ }
  .site-nav__chevron { width: 20px; height: 20px; }

  /* ── Mobile nav: hidden by default (desktop) ─────────── */
  .mobile-nav { display: none; }

  /* ── Mobile breakpoint (<768px) ──────────────────────── */
  @media (max-width: 767px) {
    .site-nav { display: none; }

    /* Position details relative to header inner for the dropdown */
    .site-header__inner { position: relative; flex-wrap: wrap; }

    .mobile-nav {
      display: block;
      /* Reset browser <details> styles */
      list-style: none;
    }
    .mobile-nav > summary { list-style: none; }
    .mobile-nav > summary::-webkit-details-marker { display: none; }

    .mobile-nav__toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      cursor: pointer;
      color: var(--color-ink);
      background: none;
      border: none;
      border-radius: 8px;
      /* Remove default details focus outline and replace with custom */
      outline: none;
    }
    .mobile-nav__toggle:focus-visible {
      outline: 2px solid var(--color-ink);
      outline-offset: 2px;
    }

    /* Show hamburger, hide close by default */
    .mobile-nav__icon--open  { display: block; }
    .mobile-nav__icon--close { display: none; }

    /* When open: swap icons */
    .mobile-nav[open] .mobile-nav__icon--open  { display: none; }
    .mobile-nav[open] .mobile-nav__icon--close { display: block; }

    /* Dropdown panel — hidden when details is closed */
    .mobile-nav__menu {
      display: none;
    }
    .mobile-nav[open] .mobile-nav__menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-top: 1px solid var(--border-subtle);
      padding: var(--space-4) var(--container-pad);
      display: flex;
      flex-direction: column;
      gap: 0;
      z-index: 100;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .mobile-nav__item {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 20px;
      line-height: 1.2;
      letter-spacing: -0.4px;
      color: var(--color-ink);
      white-space: nowrap;
      padding-block: var(--space-4); /* 16px top+bottom = 48px tap target */
      border-bottom: 1px solid var(--border-subtle);
      display: flex;
      align-items: center;
    }
    .mobile-nav__item:last-child { border-bottom: none; }

    .mobile-nav__item--dropdown { gap: var(--space-1); }
    .mobile-nav__chevron { width: 20px; height: 20px; }
  }
</style>
