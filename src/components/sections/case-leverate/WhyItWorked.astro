---
// Leverate case — section-why-it-worked (Figma 1948:404). Тёмный фон, текст с тремя
// пунктами (bold lead + body), затем phone-mockup PNG на белом фоне с rounded-углами.
---
<section class="lc-why">
  <div class="lc-why__inner">
    <!-- Text block -->
    <div class="lc-why__text">
      <h2 class="lc-why__title">Why it worked</h2>

      <ul class="lc-why__list">
        <li class="lc-why__item">
          <p class="lc-why__item-body">
            <strong class="lc-why__item-lead">C-Level executives fully involved in the process</strong><br />
            Leverate showed up week after week, gave detailed feedback, and pushed the process forward.
          </p>
        </li>
        <li class="lc-why__item">
          <p class="lc-why__item-body">
            <strong class="lc-why__item-lead">Parallel tracks that didn't collide</strong><br />
            Each workstream — brand, product, web, print — had its own dedicated designer and its own client counterpart. Tracks moved in parallel without blocking each other, so the output compounded instead of queuing.
          </p>
        </li>
        <li class="lc-why__item">
          <p class="lc-why__item-body">
            <strong class="lc-why__item-lead">A gradual buildup of the brand style</strong><br />
            We didn't start with the brand book. It naturally evolved along with the building of the website, constructing the UI and printing the merch. Brand book was not a starting point, it was the destination.
          </p>
        </li>
      </ul>
    </div>

    <!-- Phone mockup visual -->
    <div class="lc-why__mockup-wrap">
      <img
        class="lc-why__mockup"
        src="/assets/case-leverate/why-it-worked-phone.png"
        alt="Leverate branded website shown on phone mockups"
        width="2720"
        height="1940"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .lc-why {
    width: 100%;
    background: var(--case-bg);
  }

  .lc-why__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Text block ── */
  .lc-why__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
    color: #fff;
    width: 100%;
  }

  /* Factor A Bold 62/62, tracking -1.24px */
  .lc-why__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
    width: 100%;
  }

  /* List of three reasons */
  .lc-why__list {
    margin: 0;
    padding-left: 36px;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
  }

  .lc-why__item {
    margin-bottom: 20px;
  }

  .lc-why__item:last-child {
    margin-bottom: 0;
  }

  /* Literata Regular 24/1.34, tracking -0.32px */
  .lc-why__item-body {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
    margin: 0;
  }

  /* Literata Bold — bold lead of each item */
  .lc-why__item-lead {
    font-family: var(--font-serif);
    font-weight: 700;
    font-style: normal;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
  }

  /* ── Phone mockup container: white bg, rounded, fixed height 970px ── */
  .lc-why__mockup-wrap {
    background: #fff;
    border-radius: 32px;
    height: 970px;
    overflow: hidden;
    position: relative;
    width: 100%;
    flex-shrink: 0;
  }

  .lc-why__mockup {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }

  /* ─── Адаптив ─── */
  @media (max-width: 768px) {
    .lc-why__inner {
      padding-inline: 24px;
      padding-top: 64px;
      padding-bottom: 64px;
      gap: 48px;
    }
    .lc-why__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-why__text { gap: 32px; }
    .lc-why__item-body,
    .lc-why__item-lead {
      font-size: 18px;
      line-height: 1.4;
    }
    .lc-why__list { padding-left: 24px; }
    .lc-why__mockup-wrap {
      height: 260px;
      border-radius: 20px;
    }
    .lc-why__mockup {
      width: 200%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
  }
</style>
