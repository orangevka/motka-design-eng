---
// Home Hero — 1440×592 pixel-perfect (Figma node 46:685)
// Текст слева (real text). Справа — чистые прозрачные дашборды (Figma node 80:7971,
// 698×530), бегущие лентой (marquee) над неподвижной шахматкой.

// Разные карточки можно добавлять сюда — петля останется бесшовной:
// трек = один набор + его точная копия ([набор|набор]), translateX(-50%) сбрасывается
// невидимо, т.к. вторая половина встаёт ровно на место первой.
const CARDS = ['/assets/home/hero-dashboard.png'];

// Половина (набор) должна перекрывать самый широкий экран (~2888px ≈ 4 карточки @698+24).
// Если уникальных меньше — добиваем повтором до 4, иначе на широких мониторах будет пустота.
const PER_HALF = Math.max(4, CARDS.length);
const half = Array.from({ length: PER_HALF }, (_, i) => CARDS[i % CARDS.length]);
const track = [...half, ...half]; // две идентичные половины → бесшовный -50%

// Длительность держит ~72px/с на десктопе при любом числе карточек (шаг 698+24=722).
const durationS = Math.round((PER_HALF * 722) / 72);
---

<section class="hero">
  <div class="hero__inner">
    <h1 class="hero__title">Senior <br class="hero__br" />design <br class="hero__br" />partner</h1>
    <p class="hero__subtitle">UX/UI and branding for complex digital products</p>
  </div>

  <!-- Card strip — direct child of .hero (NOT inside .hero__inner) so it bleeds
       past the 1440-column right edge; .hero { overflow:hidden } clips it at the
       viewport edge. Left mirrors the illustration's 368px column offset:
       calc(50% - 720px + 368px) = calc(50% - 352px). -->
  <div class="hero-strip" aria-hidden="true">
    <div class="hero-strip__track" style={`animation-duration:${durationS}s`}>
      {track.map((src, i) => (
        <div class="hero-strip__card">
          <img
            src={src}
            alt=""
            width="698"
            height="530"
            fetchpriority={i === 0 ? 'high' : undefined}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 592px;
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    width: 100%;
    max-width: var(--container-max); /* 1440 */
    height: 100%;
    margin-inline: auto;
    z-index: 2; /* text sits above the strip (z=1) */
  }

  /* Заголовок: Factor A Bold 93/80, #333; left=37, top=112 (Figma 46:843) */
  .hero__title {
    position: absolute;
    left: 37px;
    top: 112px;
    width: 596px;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 93px;
    line-height: 80px;
    letter-spacing: -0.5px;
    color: var(--color-ink);
    z-index: 3;
  }

  /* Сабтайтл: Factor A Regular 28/32, #000; left=37.5, top=393 (Figma 46:844) */
  .hero__subtitle {
    position: absolute;
    left: 37.5px;
    top: 393px;
    width: 331px;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 32px;
    color: #000;
    z-index: 3;
  }

  /* ─── Card strip (marquee panel) ──────────────────────────────── */
  /* Панель-контейнер анимации (Figma 80:683): блок честно поделён на две части —
     слева белый фон с текстом, справа — скруглённая панель с анимацией ВНУТРИ
     колонки 1440 (не до края экрана). Левый край = 436px от левого края колонки
     (граница в макете), правый край = 40px до правого края контента (как у других
     секций). overflow:hidden + radius 24px обрезают шахматку и ленту по панели —
     анимация не вылезает ни под заголовок слева, ни за край справа.
     left/right через max(): ≥1440 привязаны к центрированной колонке, на узких
     остаются фиксированными (436px слева, 40px справа). z-index: 1 — под текстом. */
  .hero-strip {
    position: absolute;
    left: max(436px, calc(50% - 284px));
    right: max(40px, calc(50% - 680px));
    top: 0;
    height: 584px;
    overflow: hidden;
    border-radius: 24px;
    z-index: 1;
    /* Статичная шахматка-фон (клетка 32px, #fafafa/#ebebeb — как в исходном PNG).
       Лежит на неподвижном контейнере: бежит только __track внутри, фон стоит. */
    background-color: #fafafa;
    background-image: conic-gradient(#ebebeb 25%, #fafafa 0 50%, #ebebeb 0 75%, #fafafa 0);
    background-size: 64px 64px;
  }

  /* Трек: два идентичных набора, translateX(-50%) = бесшовный цикл.
     Интервал через margin-right (не gap), чтобы 50% точно совпадало. */
  .hero-strip__track {
    display: flex;
    flex-direction: row;
    align-items: center; /* 530-высокие карточки центрируются в 584-панели */
    width: max-content;
    height: 584px;
    will-change: transform;
    /* Длительность задаётся инлайн (animation-duration) из durationS под число карточек;
       40s — фолбэк для 4-карточной половины (~72px/с). */
    animation: hero-marquee 40s linear infinite;
  }

  @keyframes hero-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .hero-strip:hover .hero-strip__track {
    animation-play-state: paused;
  }

  .hero-strip__card {
    width: 698px;
    height: 530px;
    flex-shrink: 0;
    margin-right: 24px; /* интервал между картинками в карусели */
    /* Скругление + тень — в CSS (Figma: radius 8, drop-shadow 0/4/28, #E0D7D3).
       Окно экспортировано с прямыми углами → overflow:hidden скругляет его;
       box-shadow рисуется снаружи и тоже повторяет скруглённую рамку. */
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 28px 0 rgba(224, 215, 211, 1);
  }
  .hero-strip__card img {
    width: 698px;
    height: 530px;
    display: block;
  }

  /* ─── 1280 ─────────────────────────────────────────────────────── */
  @media (max-width: 1279px) {
    .hero__title {
      font-size: 80px;
      line-height: 72px;
    }
    .hero__subtitle {
      font-size: 26px;
      line-height: 30px;
    }
  }

  /* ─── 1024 ─────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .hero {
      height: 540px;
    }
    .hero__title {
      font-size: 64px;
      line-height: 60px;
    }
    .hero__subtitle {
      top: 320px;
      font-size: 22px;
      line-height: 28px;
    }
    /* Лента уменьшается, панель подгоняется под высоту hero */
    .hero-strip,
    .hero-strip__track {
      height: 540px;
    }
    .hero-strip__card,
    .hero-strip__card img {
      width: 500px;
      height: 380px;
    }
  }

  /* ─── 768 и ниже: стек — текст сверху, лента полосой снизу ─── */
  @media (max-width: 768px) {
    .hero {
      height: auto;
      overflow: hidden;
    }
    .hero__inner {
      height: auto;
      padding: 40px 24px 0;
    }
    /* Заголовок и сабтайтл — без принудительных переносов, текут естественно */
    .hero__br { display: none; }
    .hero__title {
      position: static;
      width: auto;
      font-size: clamp(48px, 11vw, 72px);
      line-height: 1;
    }
    .hero__subtitle {
      position: static;
      width: auto;
      max-width: none;
      margin-top: 20px;
      font-size: clamp(20px, 5.5vw, 26px);
      line-height: 1.3;
    }
    /* Лента: полноширинная полоса, обрезается, под текстом.
       Высота полосы = высота карточки + 48 → align-items:center даёт по 24px
       шахматки сверху и снизу. Карточки крупнее, чтобы их было меньше на экране. */
    .hero-strip {
      position: static;
      left: auto;
      right: auto;
      top: auto;
      width: 100%;
      height: 348px; /* 300 карточка + 24 + 24 */
      overflow: hidden;
      border-radius: 0; /* полноширинная полоса — без скруглений */
      margin-top: 32px;
    }
    .hero-strip__track {
      height: 348px;
    }
    .hero-strip__card,
    .hero-strip__card img {
      width: 395px;
      height: 300px;
    }
    .hero-strip__card {
      margin-right: 16px;
    }
  }

  /* ─── 390 ──────────────────────────────────────────────────────── */
  @media (max-width: 430px) {
    .hero__inner {
      padding: 32px 16px 0;
    }
    .hero__title {
      font-size: clamp(40px, 11vw, 52px);
    }
    .hero__subtitle {
      font-size: clamp(18px, 5vw, 22px);
    }
    /* Телефон: карточка меньше (395 шире экрана), полоса = 228 + 24 + 24 */
    .hero-strip {
      margin-top: 24px;
      height: 276px;
    }
    .hero-strip__track {
      height: 276px;
    }
    .hero-strip__card,
    .hero-strip__card img {
      width: 300px;
      height: 228px;
    }
  }

  /* ─── Reduced motion: остановить ленту ───────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-strip__track {
      animation: none;
    }
  }
</style>
