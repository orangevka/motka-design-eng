---
// FAQ section — 1440×870 pixel-perfect (Figma node 15:8788)
---

<section class="faq">
  <div class="faq__inner">

    <h2 class="faq__heading">Questions</h2>

    <div class="faq__body">

      <!-- Accordion column -->
      <div class="faq__accordion">

        <!-- Item 1: OPEN by default -->
        <details class="faq__item faq__item--open" open>
          <summary class="faq__summary">
            <span class="faq__question">What tasks can I submit?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">Anything across product, marketing and brand — UI screens, landing pages, ad creatives, decks, campaign visuals, design system work, event materials and more.</p>
        </details>

        <!-- Item 2 -->
        <details class="faq__item">
          <summary class="faq__summary">
            <span class="faq__question">What does "1 active task at a time" mean?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">We work on one task at a time from your queue. While the current task is in progress, you can queue up as many requests as you like. Tasks are completed sequentially so each gets full attention.</p>
        </details>

        <!-- Item 3 -->
        <details class="faq__item">
          <summary class="faq__summary">
            <span class="faq__question">Is this good for product design, not just marketing?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">Yes. We cover full product UI — flows, components, design systems, interactive prototypes — as well as marketing, brand, and everything in between.</p>
        </details>

        <!-- Item 4 -->
        <details class="faq__item">
          <summary class="faq__summary">
            <span class="faq__question">Can I pause?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">Yes. Pause or cancel at any time. Unused subscription days roll over to your next active period when you resume.</p>
        </details>

        <!-- Item 5 -->
        <details class="faq__item">
          <summary class="faq__summary">
            <span class="faq__question">What's not included?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">We don't do video editing, code implementation, 3D modelling, or copy writing. Everything else design-related is fair game.</p>
        </details>

        <!-- Item 6 -->
        <details class="faq__item">
          <summary class="faq__summary">
            <span class="faq__question">How quickly can I expect results?</span>
            <span class="faq__chevron" aria-hidden="true">
              <img class="faq__chevron-up"   src="/assets/faq/chevron-up.svg"   alt="" width="32" height="32" />
              <img class="faq__chevron-down" src="/assets/faq/chevron-down.svg" alt="" width="32" height="32" />
            </span>
          </summary>
          <p class="faq__answer">First drafts are delivered within 48 hours of kick-off. Most tasks are completed in 1–3 business days depending on complexity.</p>
        </details>

      </div><!-- /.faq__accordion -->

      <!-- Dark CTA card -->
      <div class="faq__card">
        <div class="faq__card-inner">

          <!-- Upper group: graphic + text (gap-16 between them) -->
          <div class="faq__card-upper">
            <div class="faq__card-graphic">
              <div class="faq__card-graphic-group">
                <img src="/assets/faq/card-graphic.svg" alt="" class="faq__graphic-group2" width="52" height="52" aria-hidden="true" />
              </div>
              <div class="faq__card-squares">
                <div class="faq__sq faq__sq--gradient"></div>
                <div class="faq__sq faq__sq--green"></div>
                <div class="faq__sq faq__sq--blue1"></div>
                <div class="faq__sq faq__sq--blue2"></div>
              </div>
              <img src="/assets/faq/card-union.svg" alt="" class="faq__union" width="108" height="108" aria-hidden="true" />
            </div>

            <!-- Text content -->
            <div class="faq__card-text">
              <h3 class="faq__card-heading">No more design bottlenecks</h3>
              <p class="faq__card-body">Design that has been holding up your next release, this is what we unblock first.</p>
            </div>
          </div>

          <!-- CTA -->
          <div class="faq__card-cta">
            <a href="/contacts.html" class="faq__cta-btn">Book a call</a>
            <p class="faq__cta-note">First drafts within 48 hours of kick-off.</p>
          </div>

        </div>
      </div><!-- /.faq__card -->

    </div><!-- /.faq__body -->

  </div><!-- /.faq__inner -->
</section>

<style>
  /* ─── Section wrapper ───────────────────────────────────────── */
  .faq {
    width: 100%;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-inline: 80px;
    padding-block: 64px;
    box-sizing: border-box;
  }

  .faq__inner {
    width: 100%;
    max-width: calc(var(--container-max) - 160px); /* 1440 - 2×80px */
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ─── Section heading ──────────────────────────────────────── */
  .faq__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 32px;
    line-height: 38px;
    color: var(--color-ink);
    margin: 0;
  }

  /* ─── Two-column body ──────────────────────────────────────── */
  .faq__body {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    width: 100%;
  }

  /* ─── Accordion column ─────────────────────────────────────── */
  .faq__accordion {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-self: stretch;
  }

  /* ─── Individual accordion item ────────────────────────────── */
  .faq__item {
    background: var(--color-sand); /* #f3efed — closed state */
    border-radius: 24px;
    overflow: hidden;
    position: relative;
  }

  /* Open item gets white bg with border + shadow (matching Figma node 15:8793) */
  .faq__item[open] {
    background: var(--color-bg);
    border: 1.417px solid var(--border-subtle); /* #f3efed */
    box-shadow: 0px 31px 24px -36px rgba(30, 18, 12, 0.3);
  }

  /* ─── Summary row ───────────────────────────────────────────── */
  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 36px;
    padding-top: 30px; /* 28px + 2px top-offset from Figma */
    list-style: none;
    cursor: pointer;
    gap: 16px;
  }

  /* Remove native disclosure marker in all browsers */
  .faq__summary::-webkit-details-marker { display: none; }
  .faq__summary::marker { display: none; }

  /* ─── Question text ─────────────────────────────────────────── */
  .faq__question {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 24px;
    color: var(--color-ink);
    flex: 1 0 0;
    min-width: 0;
  }

  /* ─── Chevron icon ──────────────────────────────────────────── */
  .faq__chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
  }

  /* Show down-chevron when closed, up-chevron when open */
  .faq__item .faq__chevron-up   { display: none; }
  .faq__item .faq__chevron-down { display: block; }
  .faq__item[open] .faq__chevron-up   { display: block; }
  .faq__item[open] .faq__chevron-down { display: none; }

  .faq__chevron img {
    width: 32px;
    height: 32px;
    display: block;
  }

  /* ─── Answer text ───────────────────────────────────────────── */
  .faq__answer {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: -0.4px;
    color: var(--color-text-secondary);
    margin: 0;
    padding: 0 36px 28px;
  }

  /* ─── Dark CTA card ─────────────────────────────────────────── */
  .faq__card {
    background: #050505;
    border-radius: 24px;
    width: 457px;
    height: 672px;
    flex-shrink: 0;
    overflow: hidden;
    padding: 28px;
    box-sizing: border-box;
    display: flex;
  }

  .faq__card-inner {
    flex: 1 0 0;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
    justify-content: flex-end;
    border-radius: 24px;
  }

  /* ─── Upper group: graphic + text stacked with 16px gap ────── */
  .faq__card-upper {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
  }

  /* ─── Decorative graphic area ──────────────────────────────── */
  .faq__card-graphic {
    width: 100%;
    height: 207px;
    position: relative;
    flex-shrink: 0;
  }

  /* group2 icon — rotated 180deg, centered in graphic area */
  .faq__card-graphic-group {
    position: absolute;
    left: 175.91px;
    top: 113.2px;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .faq__graphic-group2 {
    transform: rotate(180deg);
    display: block;
  }

  /* The 4 colored squares cluster */
  .faq__card-squares {
    position: absolute;
    left: 173.91px;
    top: -39.8px;
  }

  .faq__sq {
    position: absolute;
    width: 26px;
    height: 26px;
  }

  /* gradient square: left offset, top row */
  .faq__sq--gradient {
    left: 0;
    top: 52px; /* 12.2 - (-39.8) = 52 */
    background: linear-gradient(180deg, #627dff 0%, #ff5500 100%);
    transform: rotate(-90deg);
  }

  /* green square: right, top row */
  .faq__sq--green {
    left: 26px;
    top: 52px;
    background: #54b87f;
  }

  /* blue1: right, middle row */
  .faq__sq--blue1 {
    left: 26px;
    top: 26px;
    background: #627dff;
  }

  /* blue2: right, top row - 26 */
  .faq__sq--blue2 {
    left: 26px;
    top: 0;
    background: #627dff;
  }

  /* Union bracket graphic */
  .faq__union {
    position: absolute;
    left: 145.91px;
    top: 57.2px;
    width: 108px;
    height: 108px;
    display: block;
  }

  /* ─── Card text block ───────────────────────────────────────── */
  .faq__card-text {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .faq__card-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 38px;
    line-height: 46px;
    color: #ffffff;
    margin: 0;
  }

  .faq__card-body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    line-height: 26px;
    color: #ffffff;
    margin: 0;
  }

  /* ─── Card CTA block ────────────────────────────────────────── */
  .faq__card-cta {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
  }

  .faq__cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cta); /* #6cd6ab */
    color: var(--color-ink);
    border-radius: var(--radius-2xl); /* 16px */
    padding: 20px 32px 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 24px;
    text-decoration: none;
    width: 100%;
    box-sizing: border-box;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .faq__cta-note {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 16px;
    line-height: 22px;
    color: #ffffff;
    text-align: center;
    margin: 0;
    width: 100%;
  }
</style>
