---
// Footer — 1440×381 pixel-perfect (Figma node 15:8852)
---

<footer class="site-footer">
  <div class="container">
    <div class="footer__panel">

      <!-- Logo/mark decorative area (top-left of panel right half) -->
      <div class="footer__mark" aria-hidden="true">
        <img class="footer__mark-bg" src="/assets/footer/mark-bg.png" alt="" width="240" height="180" />
        <img class="footer__mark-img" src="/assets/footer/logo-mark.svg" alt="" width="41" height="80" />
      </div>

      <!-- Main column -->
      <nav class="footer__col footer__col--main" aria-label="Main navigation">
        <p class="footer__col-heading">Main</p>
        <ul class="footer__links">
          <li><a href="/#how-we-work" class="footer__link">How do we work</a></li>
          <li><a href="/#testimonials" class="footer__link">What clients say</a></li>
          <li><a href="/about.html" class="footer__link">About us</a></li>
          <li><a href="/contacts.html" class="footer__link">Contacts</a></li>
        </ul>
      </nav>

      <!-- Portfolio column (two sub-columns merged) -->
      <nav class="footer__col footer__col--portfolio" aria-label="Portfolio">
        <p class="footer__col-heading">Portfolio</p>
        <div class="footer__portfolio-cols">
          <ul class="footer__links">
            <li><a href="/portfolio.html" class="footer__link">Logistic SaaS</a></li>
            <li><a href="/portfolio.html" class="footer__link">Mobile app for VR/AR</a></li>
            <li><a href="/portfolio.html" class="footer__link">Branding for school</a></li>
            <li><a href="/portfolio.html" class="footer__link">Edtech platform</a></li>
          </ul>
          <ul class="footer__links">
            <li><a href="/portfolio.html" class="footer__link">UI design for a SaaS</a></li>
            <li><a href="/portfolio.html" class="footer__link">Mobile app for gifts</a></li>
            <li><a href="/portfolio.html" class="footer__link">Branded illustrations</a></li>
            <li><a href="/portfolio.html" class="footer__link">Catchy branding</a></li>
            <li><a href="/portfolio.html" class="footer__link footer__link--muted">and more...</a></li>
          </ul>
        </div>
      </nav>

      <!-- Right area: socials + privacy/copyright -->
      <div class="footer__right">
        <div class="footer__socials">
          <a href="https://clutch.co" class="footer__social" target="_blank" rel="noopener noreferrer">Clutch</a>
          <span class="footer__dot" aria-hidden="true">·</span>
          <a href="https://linkedin.com" class="footer__social" target="_blank" rel="noopener noreferrer">Linkedin</a>
          <span class="footer__dot" aria-hidden="true">·</span>
          <a href="https://behance.net" class="footer__social" target="_blank" rel="noopener noreferrer">Behance</a>
        </div>
        <div class="footer__legal">
          <a href="/privacy.html" class="footer__privacy">Privacy policy</a>
          <p class="footer__copy">© 2026 Motka&nbsp; All rights reserved.</p>
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  /* ─── Outer wrapper ──────────────────────────────────────────── */
  .site-footer {
    width: 100%;
    background: var(--color-bg);
    padding-bottom: 20px;
  }

  /* ─── Sand panel ─────────────────────────────────────────────── */
  /* Figma: 1360×381, rounded 24px, bg #f3efed */
  /* Within 1440 container (pad 40px): 1440 - 80 = 1360px */
  .footer__panel {
    position: relative;
    width: 100%;
    height: 381px;
    background: var(--color-sand); /* #f3efed */
    border-radius: 24px;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ─── Logo/mark decorative element ───────────────────────────── */
  /* Figma: left=760, top=0, w=240, h=180 (within 1360px panel) */
  /* The group2087329411 SVG (sparkle icon) is at x=93.41, y=43 within that 240×180 area */
  /* So absolute from panel left: 760+93.41 ≈ 853px */
  /* Mark area = checkerboard placeholder bg (Figma image 709) + sparkle on top.
     Figma: area at panel x=760, y=0, w=240, h=180; sparkle at x=93,y=43 within it. */
  .footer__mark {
    position: absolute;
    left: 760px;
    top: 0;
    width: 240px;
    height: 180px;
    pointer-events: none;
    z-index: 0;
  }

  .footer__mark-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .footer__mark-img {
    position: absolute;
    left: 93px;
    top: 43px;
    width: 41px;
    height: 80px;
    display: block;
  }

  /* ─── Main column ────────────────────────────────────────────── */
  /* Figma: left=58, top=119, w=138 */
  .footer__col--main {
    position: absolute;
    left: 58px;
    top: 119px;
    width: 138px;
  }

  /* ─── Portfolio column ───────────────────────────────────────── */
  /* Figma: heading at left=300, top=119; links start at 300, top=159 */
  /* Extended col starts at left=542, top=159 */
  .footer__col--portfolio {
    position: absolute;
    left: 300px;
    top: 119px;
    width: 449px; /* 542+207 - 300 = 449 */
  }

  /* ─── Column shared styles ───────────────────────────────────── */
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__col-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 24px;
    color: #000000;
    margin: 0;
  }

  /* ─── Link lists ─────────────────────────────────────────────── */
  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer__link {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-text-secondary); /* #4a4a4a */
    text-decoration: none;
  }

  .footer__link--muted {
    opacity: 0.5;
  }

  /* ─── Portfolio two sub-columns ──────────────────────────────── */
  /* Figma: col1 at left=300, col2 at left=542 → gap = 542-300 = 242px */
  /* Each col is 207px wide → but col1's heading is min-content ("Portfolio") */
  .footer__portfolio-cols {
    display: flex;
    gap: 35px; /* 542-300 = 242px total from heading left to col2 left; col1 links are 207px wide */
  }

  /* col1 links: 207px wide per Figma node 15:8863 */
  .footer__portfolio-cols .footer__links:first-child {
    width: 207px;
    flex-shrink: 0;
  }

  /* col2 links: 207px wide per Figma node 15:8868 */
  .footer__portfolio-cols .footer__links:last-child {
    width: 207px;
    flex-shrink: 0;
  }

  /* ─── Right area ─────────────────────────────────────────────── */
  /* Figma: socials at left=1039, top=121; privacy at left=1039, top=178 */
  .footer__right {
    position: absolute;
    left: 1039px;
    top: 121px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ─── Social links row ───────────────────────────────────────── */
  /* Figma: font-size 16px, bold, gap 8px, whitespace nowrap */
  .footer__socials {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 20px;
    white-space: nowrap;
    margin-bottom: 37px; /* privacy top=178, socials top=121, lh=20 → 178-(121+20)=37px */
  }

  .footer__social {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    line-height: 20px;
    color: #000000;
    text-decoration: none;
  }

  .footer__dot {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
    color: #000000;
  }

  /* ─── Privacy + copyright ────────────────────────────────────── */
  /* Figma: 14px Regular, left=1039, top=178 */
  .footer__legal {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__privacy {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #000000;
    text-decoration: none;
    display: block;
  }

  .footer__copy {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #000000;
    margin: 0;
    white-space: nowrap;
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — 1280px and below
     Switch from absolute positioning to flex-row layout
     ═══════════════════════════════════════════════════════════════ */

  @media (max-width: 1439px) {
    /* Panel becomes auto-height, flex row.
       Switch BEFORE 1440: absolute desktop layout assumes a 1360px panel
       (viewport ≥1440); below that the right column would overflow the panel. */
    .footer__panel {
      height: auto;
      padding: 40px 40px 40px 40px;
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 40px;
      overflow: visible;
    }

    /* Hide decorative mark at smaller sizes — it was absolutely placed */
    .footer__mark {
      display: none;
    }

    /* Reset absolute positioning for all columns */
    .footer__col--main,
    .footer__col--portfolio,
    .footer__right {
      position: static;
      top: auto;
      left: auto;
    }

    /* Main col: fixed width */
    .footer__col--main {
      width: 130px;
      flex-shrink: 0;
    }

    /* Portfolio col: take available space */
    .footer__col--portfolio {
      width: auto;
      flex: 1 1 auto;
      min-width: 0;
    }

    /* Right block: shrink to content, align end */
    .footer__right {
      flex-shrink: 0;
      align-self: flex-start;
    }

    /* Tighten portfolio sub-col gap at 1280 */
    .footer__portfolio-cols .footer__links:first-child,
    .footer__portfolio-cols .footer__links:last-child {
      width: auto;
      flex: 1 1 auto;
    }

    .footer__portfolio-cols {
      gap: 24px;
    }

    /* Reduce socials bottom margin */
    .footer__socials {
      margin-bottom: 24px;
    }
  }

  /* ─── 1024px ─────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .footer__panel {
      padding: 32px 28px;
      gap: 28px;
    }

    .footer__col-heading,
    .footer__link {
      font-size: 16px;
    }
  }

  /* ─── 768px: stack to 2 rows (nav cols top, right block bottom) ─ */
  @media (max-width: 767px) {
    .footer__panel {
      flex-direction: column;
      padding: 32px 24px;
      gap: 32px;
      border-radius: 20px;
    }

    /* Row 1: Main + Portfolio side by side */
    .footer__col--main {
      width: auto;
      flex-shrink: 1;
    }

    .footer__col--portfolio {
      flex: 1 1 auto;
    }

    /* Row 2: socials/legal block — full width */
    .footer__right {
      width: 100%;
    }

    .footer__socials {
      margin-bottom: 16px;
    }

    /* Wrap the two nav cols in a row via wrapper trick:
       Use a wrapper element approach by targeting them as siblings in the panel */
    /* Main + Portfolio sit in a flex row still, right block goes below */
    .footer__panel {
      flex-direction: column;
    }

    /* Group the nav columns in an inline flex row */
    .footer__col--main,
    .footer__col--portfolio {
      display: flex; /* already flex-col; keep */
    }

    /* Create a nav row wrapper at 768 via CSS grid */
    .footer__panel {
      display: grid;
      grid-template-areas:
        "nav-main nav-portfolio"
        "right    right";
      grid-template-columns: auto 1fr;
      gap: 32px 32px;
    }

    .footer__col--main       { grid-area: nav-main; }
    .footer__col--portfolio  { grid-area: nav-portfolio; }
    .footer__right           { grid-area: right; }
  }

  /* ─── 390px: full single-column stack ───────────────────────── */
  @media (max-width: 480px) {
    .footer__panel {
      display: flex;
      flex-direction: column;
      padding: 28px 20px;
      gap: 28px;
      border-radius: 16px;
    }

    .footer__col--main,
    .footer__col--portfolio {
      width: 100%;
    }

    .footer__portfolio-cols {
      gap: 16px;
    }

    .footer__portfolio-cols .footer__links:first-child,
    .footer__portfolio-cols .footer__links:last-child {
      width: auto;
      flex: 1 1 0;
    }

    .footer__right {
      width: 100%;
    }

    .footer__socials {
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .footer__copy {
      white-space: normal;
    }
  }
</style>
