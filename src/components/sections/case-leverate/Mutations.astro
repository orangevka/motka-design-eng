---
// Leverate case — section-mutations (Figma 1946:504, 1440×1254).
// Заголовок + body-текст сверху (HTML), три колонки отвергнутых мокапов ниже (PNG 2×).
---
<section class="lc-mut">
  <div class="lc-mut__inner">

    <!-- Текстовый блок: heading + body, gap 48px (Figma 1929:17284) -->
    <div class="lc-mut__text">
      <h2 class="lc-mut__heading">Cutting out mutations</h2>
      <p class="lc-mut__body">
        Not every idea survives.&nbsp; We explored several visual directions before settling on the final approach.
        We had different ideas on logo and style.&nbsp;&nbsp;
        <br /><br />
        In the end, the strongest ideas earned their place in fierce competition.
      </p>
    </div>

    <!-- Три колонки отвергнутых мокапов — сложная композиция → PNG 2×
         (Figma node 1946:503 «mutations-row», 1360×920 @ 2× = 2720×1840) -->
    <img
      class="lc-mut__grid"
      src="/assets/case-leverate/mutations-grid.png"
      alt="Rejected design directions: billboards, app icons, alternative logos, and landing page concepts"
      width="2720"
      height="1840"
    />

  </div>
</section>

<style>
  .lc-mut {
    width: 100%;
    background: var(--case-bg);
  }
  .lc-mut__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    /* gap между текстовым блоком и сеткой: mutations-row.y - section-text.h = 334 - 270 = 64px */
    gap: 64px;
  }

  /* ── Текст ── */
  .lc-mut__text {
    display: flex;
    flex-direction: column;
    gap: 48px; /* Figma gap между heading и body */
  }

  /* Factor A Bold 62/62, tracking -1.24px (Figma 1929:17285) */
  .lc-mut__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Literata Regular 24/1.34, tracking -0.32px (Figma 1929:17286, design uses Spectral ≈ Literata) */
  .lc-mut__body {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
    margin: 0;
  }

  /* PNG 2× трёх колонок отвергнутых мокапов */
  .lc-mut__grid {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ─── адаптив ─── */
  @media (max-width: 768px) {
    .lc-mut__inner {
      padding-inline: 24px;
      gap: 48px;
    }
    .lc-mut__text { gap: 24px; }
    .lc-mut__heading {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-mut__body {
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.32px;
    }
    /* Grid PNG: full-width, height auto, no overflow */
    .lc-mut__grid {
      width: 100%;
      height: auto;
      max-width: 100%;
    }
  }
</style>
