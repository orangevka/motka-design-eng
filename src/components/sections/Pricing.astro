---
// Pricing section — 1440×1214 pixel-perfect (Figma node 15:8601)
---

<section class="pricing">
  <div class="pricing__inner">

    <!-- Header row: heading left, CTA text right -->
    <div class="pricing__header">
      <h2 class="pricing__heading">Two plans, clear pricing</h2>
      <div class="pricing__header-right">
        <p class="pricing__header-title">Not sure which plan fits?</p>
        <p class="pricing__header-sub">Book a 20-minute call. We'll map what is possible.</p>
      </div>
    </div>

    <!-- Cards row wrapper (needed for "Most requested" badge positioning) -->
    <div class="pricing__cards-wrap">

      <!-- "Most requested" badge — positioned over Standard card top -->
      <div class="pricing__badge">
        <img src="/assets/pricing/badge-star.svg" alt="" width="16" height="16" aria-hidden="true" />
        <span>Most requested</span>
      </div>

      <!-- Card: Trial -->
      <div class="pricing__card">
        <img class="pricing__hat" src="/assets/pricing/hat-trial.svg" alt="" width="56" height="56" aria-hidden="true" />
        <div class="pricing__card-header">
          <h3 class="pricing__plan-name">Trial</h3>
          <p class="pricing__plan-desc">Not sure if subscription will work for you?<br />Pick a real task from your backlog.<br />We deliver it in one week.</p>
        </div>
        <div class="pricing__price">
          <span class="pricing__price-main">Demo</span>
          <span class="pricing__price-sep">/</span>
          <span class="pricing__price-period">week</span>
        </div>
        <ul class="pricing__features">
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Available after an introduction call</span>
          </li>
          <li class="pricing__feature pricing__feature--multiline">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Free, no strings attached,<br />full test drive of the subscription</span>
          </li>
        </ul>
        <a href="/contacts.html" class="pricing__cta">Book a call</a>
      </div>

      <!-- Card: Standard -->
      <div class="pricing__card">
        <img class="pricing__hat" src="/assets/pricing/hat-standard.svg" alt="" width="56" height="56" aria-hidden="true" />
        <div class="pricing__card-header pricing__card-header--tall">
          <h3 class="pricing__plan-name">Standard</h3>
          <p class="pricing__plan-desc">For teams with one focused stream<br />of design work</p>
        </div>
        <div class="pricing__price">
          <span class="pricing__price-main">4500€</span>
          <span class="pricing__price-sep">/</span>
          <span class="pricing__price-period">month</span>
        </div>
        <ul class="pricing__features">
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Unlimited request queue</span>
          </li>
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>2 active parallel tasks max</span>
          </li>
          <li class="pricing__feature pricing__feature--multiline">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Product, marketing, and brand — all covered</span>
          </li>
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Pause or cancel anytime</span>
          </li>
          <li class="pricing__feature pricing__feature--chips">
            <div class="pricing__chips">
              <span class="pricing__chip">1 Designer</span>
              <span class="pricing__chip">1 Art Director</span>
            </div>
          </li>
        </ul>
        <a href="/contacts.html" class="pricing__cta">Book a call</a>
      </div>

      <!-- Card: Premium -->
      <div class="pricing__card">
        <img class="pricing__hat" src="/assets/pricing/hat-premium.svg" alt="" width="56" height="56" aria-hidden="true" />
        <div class="pricing__card-header pricing__card-header--tall">
          <h3 class="pricing__plan-name">Premium</h3>
          <p class="pricing__plan-desc">Invoiced monthly via SWIFT transfer.<br />VAT excluded where applicable.</p>
        </div>
        <div class="pricing__price">
          <span class="pricing__price-main">9500€</span>
          <span class="pricing__price-sep">/</span>
          <span class="pricing__price-period">month</span>
        </div>
        <ul class="pricing__features">
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Unlimited parallel tasks</span>
          </li>
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Senior designers only</span>
          </li>
          <li class="pricing__feature pricing__feature--multiline">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>All kinds of design, including animation and content</span>
          </li>
          <li class="pricing__feature">
            <img src="/assets/pricing/checkmark.svg" alt="" width="20" height="20" aria-hidden="true" />
            <span>Pause or cancel anytime</span>
          </li>
          <li class="pricing__feature pricing__feature--chips">
            <div class="pricing__chips">
              <span class="pricing__chip">2 Designers</span>
              <span class="pricing__chip">1 Art Director</span>
              <span class="pricing__chip">1 Account manager</span>
            </div>
          </li>
        </ul>
        <a href="/contacts.html" class="pricing__cta">Book a call</a>
      </div>

    </div><!-- /.pricing__cards-wrap -->

    <!-- Bottom sand strip: What happens after you subscribe -->
    <div class="pricing__strip">
      <div class="pricing__strip-inner">
        <p class="pricing__strip-heading">What happens after you subscribe</p>
        <div class="pricing__strip-divider"></div>
        <div class="pricing__step">
          <p class="pricing__step-title">Set up your workspace</p>
          <p class="pricing__step-body">We send your Trello board invite within hours of the first invoice.</p>
        </div>
        <div class="pricing__strip-divider"></div>
        <div class="pricing__step">
          <p class="pricing__step-title">Add your first tasks</p>
          <p class="pricing__step-body">Share context, references, priorities. No formal brief required.</p>
        </div>
        <div class="pricing__strip-divider"></div>
        <div class="pricing__step">
          <p class="pricing__step-title">First drafts in 24–48h</p>
          <p class="pricing__step-body">Your first designs land within two business days. Pause, resume, or cancel any time.</p>
        </div>
      </div>
    </div>

  </div><!-- /.pricing__inner -->

  <!-- Footer note -->
  <p class="pricing__footnote">Invoiced monthly via SWIFT transfer. VAT excluded where applicable.</p>
</section>

<style>
  /* ─── Section wrapper ───────────────────────────────────────────── */
  .pricing {
    width: 100%;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    padding-inline: 40px;
    padding-block: 64px;
    box-sizing: border-box;
  }

  /* White rounded container */
  .pricing__inner {
    background: var(--color-bg);
    border-radius: 24px;
    width: 100%;
    max-width: calc(var(--container-max) - 80px); /* 1440 - 2×40px padding */
    display: flex;
    flex-direction: column;
    padding-top: 48px;
    overflow: hidden;
    position: relative;
  }

  /* ─── Header ────────────────────────────────────────────────────── */
  .pricing__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    padding-inline: 0;
    margin-bottom: 56px;
  }

  .pricing__heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 44px;
    line-height: 46px;
    color: var(--color-ink);
    white-space: nowrap;
    margin: 0;
  }

  .pricing__header-right {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
    text-align: right;
  }

  .pricing__header-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 26px;
    color: var(--color-ink);
    margin: 0;
    width: 286px;
  }

  .pricing__header-sub {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-text-secondary);
    margin: 0;
    width: 419px;
  }

  /* ─── Cards wrap ────────────────────────────────────────────────── */
  .pricing__cards-wrap {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    width: 100%;
    height: 662px;
    position: relative;
    margin-bottom: -32px; /* overlap with strip */
    z-index: 2;
  }

  /* ─── "Most requested" badge ────────────────────────────────────── */
  /* Figma: right=650px from right edge of cards row, top=-18px */
  /* Badge sits above Standard card (middle card) top-center */
  .pricing__badge {
    position: absolute;
    /* center on middle card: cards-wrap is 3 equal cols + 2×20px gaps
       middle card center ≈ (1/6 + 1/2) of total width - that's tricky with flex
       Figma: right=650px from right of 1360px container */
    right: 650px;
    top: -18px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-sand);
    border: 1px solid #f3efed;
    border-radius: var(--radius-2xl);
    padding: 8px 16px;
    z-index: 10;
  }

  .pricing__badge img {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .pricing__badge span {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 1;
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* ─── Individual card ───────────────────────────────────────────── */
  .pricing__card {
    flex: 1 0 0;
    min-width: 0;
    height: 100%;
    position: relative;
    border-radius: 24px;
    padding: 48px 36px 36px;
    box-sizing: border-box;
    background: var(--color-bg);
    border: 2px solid var(--border-subtle); /* #f3efed */
    box-shadow: 0px 31px 24px -36px rgba(30, 18, 12, 0.3);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ─── Top-hat character icon (top-right corner) ─────────────────── */
  /* Figma: hat is absolute within inner content (pt-48px card), top=-24.4px → card top+23.6px */
  .pricing__hat {
    position: absolute;
    top: 24px;
    right: 36px;
    width: 56px;
    height: 56px;
    display: block;
  }

  /* ─── Card header (plan name + description) ─────────────────────── */
  .pricing__card-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-bottom: 20px;
  }

  /* Standard & Premium have explicit 134px height in Figma */
  .pricing__card-header--tall {
    min-height: 134px;
  }

  .pricing__plan-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 32px;
    line-height: 38px;
    color: var(--color-ink);
    margin: 0;
    padding-top: 2px;
  }

  .pricing__plan-desc {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ─── Price row ─────────────────────────────────────────────────── */
  .pricing__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    white-space: nowrap;
  }

  .pricing__price-main {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 43px;
    line-height: 38px;
    color: var(--color-ink);
  }

  .pricing__price-sep,
  .pricing__price-period {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 18px;
    color: var(--color-text-quaternary);
  }

  /* ─── Feature list ──────────────────────────────────────────────── */
  .pricing__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1 0 0;
  }

  .pricing__feature {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-left: 4px;
    padding-top: 2px;
  }

  .pricing__feature--multiline {
    align-items: flex-start;
  }

  .pricing__feature img {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .pricing__feature span {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: -0.4px;
    color: var(--color-text-secondary);
  }

  /* Chips row (no checkmark icon, just the chips) */
  .pricing__feature--chips {
    align-items: flex-start;
    padding-left: 0;
    padding-top: 8px;
    gap: 0;
  }

  /* ─── Role chips ─────────────────────────────────────────────────── */
  .pricing__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: flex-start;
  }

  .pricing__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fade99;
    border-radius: 20px;
    padding: 4px 16px 4px 12px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* ─── CTA button ─────────────────────────────────────────────────── */
  .pricing__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cta); /* #6cd6ab */
    color: var(--color-ink);
    border-radius: var(--radius-2xl); /* 16px */
    padding: 20px 32px 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 24px;
    text-decoration: none;
    width: 100%;
    box-sizing: border-box;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Bottom sand strip ──────────────────────────────────────────── */
  .pricing__strip {
    background: var(--color-sand); /* #f3efed */
    border-radius: 24px;
    padding: 80px 48px 48px;
    width: 1280px;
    box-sizing: border-box;
    align-self: center;
    position: relative;
    z-index: 1;
  }

  .pricing__strip-inner {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .pricing__strip-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 32px;
    line-height: 38px;
    color: var(--color-ink);
    margin: 0;
    flex: 1 0 0;
    min-width: 0;
  }

  /* Vertical divider between strip columns */
  .pricing__strip-divider {
    width: 1px;
    align-self: stretch;
    background: rgba(30, 18, 12, 0.15);
    flex-shrink: 0;
  }

  .pricing__step {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pricing__step-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 26px;
    color: var(--color-ink);
    margin: 0;
  }

  .pricing__step-body {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: -0.4px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ─── Footnote ───────────────────────────────────────────────────── */
  .pricing__footnote {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0;
    width: 585px;
  }
</style>
