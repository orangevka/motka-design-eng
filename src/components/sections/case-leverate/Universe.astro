---
// Leverate case — section-universe (Figma 2106:10283). Тёмный фон, текст + карта продуктов
// (сложная галактика с glassmorphism-карточками) — экспортирована как один PNG.
---
<section class="lc-universe">
  <div class="lc-universe__inner">

    <div class="lc-universe__text">
      <h2 class="lc-universe__title">Mapping the Leverate Universe</h2>
      <div class="lc-universe__lead">
        <p>Leverate has a constellation of products.</p>
        <p>
          SiRiX at the top as the trading platform. Prop is the next direction.<br />
          CRM, Capital, Risk and Affiliates are infrastructure modules.
        </p>
        <p>Each gets its own mark, its own design treatment, and all of them live in the same brand universe.</p>
      </div>
    </div>

    <div class="lc-universe__visual-wrap">
      <img
        class="lc-universe__visual"
        src="/assets/case-leverate/universe-content.png"
        alt=""
        aria-hidden="true"
        width="2720"
        height="1152"
      />
    </div>

  </div>
</section>

<style>
  .lc-universe {
    width: 100%;
    background: var(--case-bg);
  }
  .lc-universe__inner {
    max-width: var(--container-max); /* 1440 */
    margin-inline: auto;
    padding-inline: var(--container-pad); /* 40px */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* ── Text block ── */
  .lc-universe__text {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Factor A Bold 62px / none, tracking -1.24px */
  .lc-universe__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 62px;
    line-height: 1;
    letter-spacing: -1.24px;
    color: #fff;
    margin: 0;
  }

  /* Spectral Regular 24px / 1.34, tracking -0.32px */
  .lc-universe__lead {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.34;
    letter-spacing: -0.32px;
    color: #fff;
  }
  .lc-universe__lead p { margin: 0; }
  .lc-universe__lead p + p { margin-top: 20px; }

  /* ── Universe graphic ──
     Figma: content area is 1360px wide, 576px tall (node 2106:10036).
     The PNG is exported at 2x so natural display width = 1360px at 1440 container. */
  .lc-universe__visual-wrap {
    width: 100%;
    overflow: hidden;
  }
  .lc-universe__visual {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── адаптив ─── */
  @media (max-width: 768px) {
    .lc-universe__inner {
      padding-inline: 24px;
      padding-top: 64px;
      gap: 48px;
    }
    .lc-universe__text { gap: 24px; }
    .lc-universe__title {
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.64px;
    }
    .lc-universe__lead {
      font-size: 18px;
      line-height: 1.4;
    }
    .lc-universe__visual-wrap { overflow: visible; }
  }
</style>
