---
// Footer — 1440×381 pixel-perfect (Figma node 15:8852)
---

<footer class="site-footer">
  <div class="container">
    <div class="footer__panel">

      <!-- Logo/mark decorative area (top-left of panel right half) -->
      <div class="footer__mark" aria-hidden="true">
        <img class="footer__mark-img" src="/assets/footer/logo-mark.svg" alt="" width="41" height="80" />
      </div>

      <!-- Main column -->
      <nav class="footer__col footer__col--main" aria-label="Main navigation">
        <p class="footer__col-heading">Main</p>
        <ul class="footer__links">
          <li><a href="/#how-we-work" class="footer__link">How do we work</a></li>
          <li><a href="/#testimonials" class="footer__link">What clients say</a></li>
          <li><a href="/about.html" class="footer__link">About us</a></li>
          <li><a href="/contacts.html" class="footer__link">Contacts</a></li>
        </ul>
      </nav>

      <!-- Portfolio column (two sub-columns merged) -->
      <nav class="footer__col footer__col--portfolio" aria-label="Portfolio">
        <p class="footer__col-heading">Portfolio</p>
        <div class="footer__portfolio-cols">
          <ul class="footer__links">
            <li><a href="/portfolio.html" class="footer__link">Logistic SaaS</a></li>
            <li><a href="/portfolio.html" class="footer__link">Mobile app for VR/AR</a></li>
            <li><a href="/portfolio.html" class="footer__link">Branding for school</a></li>
            <li><a href="/portfolio.html" class="footer__link">Edtech platform</a></li>
          </ul>
          <ul class="footer__links">
            <li><a href="/portfolio.html" class="footer__link">UI design for a SaaS</a></li>
            <li><a href="/portfolio.html" class="footer__link">Mobile app for gifts</a></li>
            <li><a href="/portfolio.html" class="footer__link">Branded illustrations</a></li>
            <li><a href="/portfolio.html" class="footer__link">Catchy branding</a></li>
            <li><a href="/portfolio.html" class="footer__link footer__link--muted">and more...</a></li>
          </ul>
        </div>
      </nav>

      <!-- Right area: socials + privacy/copyright -->
      <div class="footer__right">
        <div class="footer__socials">
          <a href="https://clutch.co" class="footer__social" target="_blank" rel="noopener noreferrer">Clutch</a>
          <span class="footer__dot" aria-hidden="true">·</span>
          <a href="https://linkedin.com" class="footer__social" target="_blank" rel="noopener noreferrer">Linkedin</a>
          <span class="footer__dot" aria-hidden="true">·</span>
          <a href="https://behance.net" class="footer__social" target="_blank" rel="noopener noreferrer">Behance</a>
        </div>
        <div class="footer__legal">
          <a href="/privacy.html" class="footer__privacy">Privacy policy</a>
          <p class="footer__copy">© 2026 Motka&nbsp; All rights reserved.</p>
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  /* ─── Outer wrapper ──────────────────────────────────────────── */
  .site-footer {
    width: 100%;
    background: var(--color-bg);
    padding-bottom: 20px;
  }

  /* ─── Sand panel ─────────────────────────────────────────────── */
  /* Figma: 1360×381, rounded 24px, bg #f3efed */
  /* Within 1440 container (pad 40px): 1440 - 80 = 1360px */
  .footer__panel {
    position: relative;
    width: 100%;
    height: 381px;
    background: var(--color-sand); /* #f3efed */
    border-radius: 24px;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ─── Logo/mark decorative element ───────────────────────────── */
  /* Figma: left=760, top=0, w=240, h=180 (within 1360px panel) */
  /* The group2087329411 SVG (sparkle icon) is at x=93.41, y=43 within that 240×180 area */
  /* So absolute from panel left: 760+93.41 ≈ 853px */
  .footer__mark {
    position: absolute;
    left: 853px;
    top: 43px;
    width: 41px;
    height: 80px;
    pointer-events: none;
    z-index: 0;
  }

  .footer__mark-img {
    width: 41px;
    height: 80px;
    display: block;
  }

  /* ─── Main column ────────────────────────────────────────────── */
  /* Figma: left=58, top=119, w=138 */
  .footer__col--main {
    position: absolute;
    left: 58px;
    top: 119px;
    width: 138px;
  }

  /* ─── Portfolio column ───────────────────────────────────────── */
  /* Figma: heading at left=300, top=119; links start at 300, top=159 */
  /* Extended col starts at left=542, top=159 */
  .footer__col--portfolio {
    position: absolute;
    left: 300px;
    top: 119px;
    width: 449px; /* 542+207 - 300 = 449 */
  }

  /* ─── Column shared styles ───────────────────────────────────── */
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__col-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 24px;
    color: #000000;
    margin: 0;
  }

  /* ─── Link lists ─────────────────────────────────────────────── */
  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer__link {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    color: var(--color-text-secondary); /* #4a4a4a */
    text-decoration: none;
  }

  .footer__link--muted {
    opacity: 0.5;
  }

  /* ─── Portfolio two sub-columns ──────────────────────────────── */
  /* Figma: col1 at left=300, col2 at left=542 → gap = 542-300 = 242px */
  /* Each col is 207px wide → but col1's heading is min-content ("Portfolio") */
  .footer__portfolio-cols {
    display: flex;
    gap: 35px; /* 542-300 = 242px total from heading left to col2 left; col1 links are 207px wide */
  }

  /* col1 links: 207px wide per Figma node 15:8863 */
  .footer__portfolio-cols .footer__links:first-child {
    width: 207px;
    flex-shrink: 0;
  }

  /* col2 links: 207px wide per Figma node 15:8868 */
  .footer__portfolio-cols .footer__links:last-child {
    width: 207px;
    flex-shrink: 0;
  }

  /* ─── Right area ─────────────────────────────────────────────── */
  /* Figma: socials at left=1039, top=121; privacy at left=1039, top=178 */
  .footer__right {
    position: absolute;
    left: 1039px;
    top: 121px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ─── Social links row ───────────────────────────────────────── */
  /* Figma: font-size 16px, bold, gap 8px, whitespace nowrap */
  .footer__socials {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 20px;
    white-space: nowrap;
    margin-bottom: 37px; /* privacy top=178, socials top=121, lh=20 → 178-(121+20)=37px */
  }

  .footer__social {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    line-height: 20px;
    color: #000000;
    text-decoration: none;
  }

  .footer__dot {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
    color: #000000;
  }

  /* ─── Privacy + copyright ────────────────────────────────────── */
  /* Figma: 14px Regular, left=1039, top=178 */
  .footer__legal {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__privacy {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #000000;
    text-decoration: none;
    display: block;
  }

  .footer__copy {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #000000;
    margin: 0;
    white-space: nowrap;
  }
</style>
